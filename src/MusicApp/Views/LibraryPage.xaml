<UserControl x:Class="MusicApp.Views.LibraryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MusicApp.Controls"
             Background="Transparent">

    <ScrollViewer Style="{StaticResource ScrollViewerStyle}"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,36">
            <Border Style="{StaticResource HeroSurfaceCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="LIBRARY"
                                   Style="{StaticResource SectionEyebrowTextStyle}"/>
                        <TextBlock Text="{Binding SectionTitle}"
                                   Style="{StaticResource HeroTextStyle}"
                                   FontSize="40"
                                   Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding SectionSubtitle}"
                                   Style="{StaticResource SubtitleTextStyle}"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding OverviewSummary}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,12,0,0"/>
                        <WrapPanel Margin="0,22,0,0">
                            <Button Content="Import Tracks"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding ImportTracksCommand}"
                                    Margin="0,0,10,10"/>
                            <Button Content="Create Playlist"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding CreatePlaylistCommand}"
                                    Margin="0,0,10,10"/>
                        </WrapPanel>
                    </StackPanel>

                    <UniformGrid Grid.Column="1"
                                 Rows="2"
                                 Columns="2"
                                 Margin="20,0,0,0">
                        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,12">
                            <StackPanel>
                                <TextBlock Text="{Binding TotalTracks}" Style="{StaticResource MetricValueTextStyle}"/>
                                <TextBlock Text="Tracks" Style="{StaticResource MetricLabelTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{Binding TotalAlbums}" Style="{StaticResource MetricValueTextStyle}"/>
                                <TextBlock Text="Albums" Style="{StaticResource MetricLabelTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="{Binding TotalArtists}" Style="{StaticResource MetricValueTextStyle}"/>
                                <TextBlock Text="Artists" Style="{StaticResource MetricLabelTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding OfflineCount}" Style="{StaticResource MetricValueTextStyle}"/>
                                <TextBlock Text="Offline Tracks" Style="{StaticResource MetricLabelTextStyle}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Border>

            <WrapPanel Margin="0,20,0,0">
                <RadioButton Content="Overview"
                             Style="{StaticResource FilterChipStyle}"
                             IsChecked="{Binding SelectedSection, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Overview}"/>
                <RadioButton Content="All Tracks"
                             Style="{StaticResource FilterChipStyle}"
                             IsChecked="{Binding SelectedSection, Converter={StaticResource EnumMatchConverter}, ConverterParameter=AllTracks}"/>
                <RadioButton Content="Liked"
                             Style="{StaticResource FilterChipStyle}"
                             IsChecked="{Binding SelectedSection, Converter={StaticResource EnumMatchConverter}, ConverterParameter=LikedTracks}"/>
                <RadioButton Content="Favorite Artists"
                             Style="{StaticResource FilterChipStyle}"
                             IsChecked="{Binding SelectedSection, Converter={StaticResource EnumMatchConverter}, ConverterParameter=FavoriteArtists}"/>
                <RadioButton Content="Albums"
                             Style="{StaticResource FilterChipStyle}"
                             IsChecked="{Binding SelectedSection, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Albums}"/>
                <RadioButton Content="Playlists"
                             Style="{StaticResource FilterChipStyle}"
                             IsChecked="{Binding SelectedSection, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Playlists}"/>
                <RadioButton Content="Offline"
                             Style="{StaticResource FilterChipStyle}"
                             IsChecked="{Binding SelectedSection, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Offline}"/>
                <RadioButton Content="Recent"
                             Style="{StaticResource FilterChipStyle}"
                             IsChecked="{Binding SelectedSection, Converter={StaticResource EnumMatchConverter}, ConverterParameter=RecentlyPlayed}"/>
                <RadioButton Content="Pinned"
                             Style="{StaticResource FilterChipStyle}"
                             IsChecked="{Binding SelectedSection, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Pinned}"/>
            </WrapPanel>

            <Border Style="{StaticResource SurfaceCardStyle}"
                    Margin="0,20,0,0"
                    Visibility="{Binding HasAnyLibraryContent, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}">
                <StackPanel Width="520" HorizontalAlignment="Center">
                    <TextBlock Text="The library foundation is in place."
                               Style="{StaticResource TitleTextStyle}"
                               TextAlignment="Center"/>
                    <TextBlock Text="Import tracks to unlock recent sessions, favorite artists, saved albums, pinned playlists, and stronger recommendation signals."
                               Style="{StaticResource SubtitleTextStyle}"
                               Margin="0,12,0,0"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                    <Button Content="Import Tracks"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding ImportTracksCommand}"
                            HorizontalAlignment="Center"
                            Margin="0,18,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Margin="0,22,0,0"
                        Visibility="{Binding IsOverview, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Recently Played"
                           Style="{StaticResource TitleTextStyle}"/>
                <ItemsControl ItemsSource="{Binding RecentlyPlayedTracks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:TrackRowControl Title="{Binding Title}"
                                                      Artist="{Binding ArtistName}"
                                                      Album="{Binding AlbumTitle}"
                                                      Duration="{Binding DurationFormatted}"
                                                      CoverArtUrl="{Binding CoverArtUrl}"
                                                      Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"
                                                      Margin="0,0,0,8"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Favorite Artists"
                           Style="{StaticResource TitleTextStyle}"
                           Margin="0,24,0,0"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding FavoriteArtists}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:ArtistCircleCard ArtistName="{Binding Name}"
                                                           ImageUrl="{Binding ImageUrl}"
                                                           Command="{Binding DataContext.NavigateToArtistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                           CommandParameter="{Binding Id}"
                                                           Margin="0,0,14,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock Text="Saved Albums"
                           Style="{StaticResource TitleTextStyle}"
                           Margin="0,24,0,0"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding SavedAlbums}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:AlbumCard Title="{Binding Title}"
                                                    Artist="{Binding ArtistName}"
                                                    CoverArtUrl="{Binding CoverArtUrl}"
                                                    Year="{Binding ReleaseYear}"
                                                    Command="{Binding DataContext.NavigateToAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    Margin="0,0,14,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <StackPanel Margin="0,22,0,0"
                        Visibility="{Binding IsAllTracks, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding AllTracks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:TrackRowControl Title="{Binding Title}"
                                                      Artist="{Binding ArtistName}"
                                                      Album="{Binding AlbumTitle}"
                                                      Duration="{Binding DurationFormatted}"
                                                      CoverArtUrl="{Binding CoverArtUrl}"
                                                      Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"
                                                      Margin="0,0,0,8"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Margin="0,22,0,0"
                        Visibility="{Binding IsLikedTracks, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding LikedTracks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:TrackRowControl Title="{Binding Title}"
                                                      Artist="{Binding ArtistName}"
                                                      Album="{Binding AlbumTitle}"
                                                      Duration="{Binding DurationFormatted}"
                                                      CoverArtUrl="{Binding CoverArtUrl}"
                                                      Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"
                                                      Margin="0,0,0,8"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <WrapPanel Margin="0,22,0,0"
                       Visibility="{Binding IsFavoriteArtists, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding FavoriteArtists}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:ArtistCircleCard ArtistName="{Binding Name}"
                                                       ImageUrl="{Binding ImageUrl}"
                                                       Command="{Binding DataContext.NavigateToArtistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       CommandParameter="{Binding Id}"
                                                       Margin="0,0,16,16"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </WrapPanel>

            <WrapPanel Margin="0,22,0,0"
                       Visibility="{Binding IsAlbums, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding SavedAlbums}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:AlbumCard Title="{Binding Title}"
                                                Artist="{Binding ArtistName}"
                                                CoverArtUrl="{Binding CoverArtUrl}"
                                                Year="{Binding ReleaseYear}"
                                                Command="{Binding DataContext.NavigateToAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}"
                                                Margin="0,0,16,16"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </WrapPanel>

            <WrapPanel Margin="0,22,0,0"
                       Visibility="{Binding IsPlaylists, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding Playlists}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:PlaylistCard Title="{Binding Title}"
                                                   Subtitle="{Binding OwnerName}"
                                                   CoverArtUrl="{Binding CoverArtUrl}"
                                                   Command="{Binding DataContext.NavigateToPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding Id}"
                                                   Margin="0,0,16,16"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </WrapPanel>

            <StackPanel Margin="0,22,0,0"
                        Visibility="{Binding IsOffline, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Offline content"
                           Style="{StaticResource TitleTextStyle}"/>
                <TextBlock Text="{Binding OfflineCollectionsSummary}"
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,4,0,14"
                           TextWrapping="Wrap"/>

                <ItemsControl ItemsSource="{Binding OfflineTracks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:TrackRowControl Title="{Binding Title}"
                                                      Artist="{Binding ArtistName}"
                                                      Album="{Binding AlbumTitle}"
                                                      Duration="{Binding DurationFormatted}"
                                                      CoverArtUrl="{Binding CoverArtUrl}"
                                                      Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"
                                                      Margin="0,0,0,8"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Downloaded albums"
                           Style="{StaticResource LabelTextStyle}"
                           Margin="0,18,0,0"
                           Visibility="{Binding HasDownloadedAlbums, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <ItemsControl ItemsSource="{Binding DownloadedAlbums}"
                              Margin="0,10,0,0"
                              Visibility="{Binding HasDownloadedAlbums, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:AlbumCard Title="{Binding Title}"
                                                Artist="{Binding ArtistName}"
                                                CoverArtUrl="{Binding CoverArtUrl}"
                                                Year="{Binding ReleaseYear}"
                                                Command="{Binding DataContext.NavigateToAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}"
                                                Margin="0,0,16,16"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Offline playlists"
                           Style="{StaticResource LabelTextStyle}"
                           Margin="0,18,0,0"
                           Visibility="{Binding HasDownloadedPlaylists, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <ItemsControl ItemsSource="{Binding DownloadedPlaylists}"
                              Margin="0,10,0,0"
                              Visibility="{Binding HasDownloadedPlaylists, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:PlaylistCard Title="{Binding Title}"
                                                   Subtitle="{Binding OwnerName}"
                                                   CoverArtUrl="{Binding CoverArtUrl}"
                                                   Command="{Binding DataContext.OpenPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding Id}"
                                                   Margin="0,0,16,16"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Margin="0,22,0,0"
                        Visibility="{Binding IsRecentlyPlayed, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding RecentlyPlayedTracks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:TrackRowControl Title="{Binding Title}"
                                                      Artist="{Binding ArtistName}"
                                                      Album="{Binding AlbumTitle}"
                                                      Duration="{Binding DurationFormatted}"
                                                      CoverArtUrl="{Binding CoverArtUrl}"
                                                      Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"
                                                      Margin="0,0,0,8"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <WrapPanel Margin="0,22,0,0"
                       Visibility="{Binding IsPinned, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding PinnedPlaylists}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:PlaylistCard Title="{Binding Title}"
                                                   Subtitle="{Binding OwnerName}"
                                                   CoverArtUrl="{Binding CoverArtUrl}"
                                                   Command="{Binding DataContext.NavigateToPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding Id}"
                                                   Margin="0,0,16,16"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
