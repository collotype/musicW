<UserControl x:Class="MusicApp.Views.LibraryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MusicApp.Controls"
             Background="{StaticResource AppBackgroundBrush}">

    <ScrollViewer Style="{StaticResource ScrollViewerStyle}"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Header -->
            <Grid Margin="32,32,32,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Your Library"
                           Style="{StaticResource HeroTextStyle}"/>
                <Button Grid.Column="1"
                        Content="Import Tracks"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ImportTracksCommand}"/>
            </Grid>

            <!-- Stats Row -->
            <StackPanel Orientation="Horizontal"
                        Margin="32,0,32,24"
                        Visibility="{Binding HasLibrarySummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="24"
                        Margin="0,0,12,0"
                        MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalTracks}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Tracks"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="24"
                        Margin="0,0,12,0"
                        MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalAlbums}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Albums"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="24"
                        Margin="0,0,12,0"
                        MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalArtists}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Artists"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="24"
                        MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="{Binding LikedCount}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Liked"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Quick Access -->
            <StackPanel Margin="32,0,32,32">
                <TextBlock Text="Quick Access"
                           Style="{StaticResource TitleTextStyle}"
                           Margin="0,0,0,16"/>
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Padding="20,12"
                            Margin="0,0,12,0"
                            Command="{Binding NavigateToFavoritesCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="♥" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Liked Songs"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Padding="20,12"
                            Margin="0,0,12,0"
                            Command="{Binding NavigateToOfflineCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⬇" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Offline"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Padding="20,12"
                            Margin="0,0,12,0"
                            Command="{Binding ImportTracksCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Import Tracks"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Padding="20,12"
                            Command="{Binding CreatePlaylistCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="New Playlist"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <Border Margin="32,0,32,32"
                    Padding="28"
                    CornerRadius="16"
                    Background="{StaticResource CardBackgroundBrush}"
                    Visibility="{Binding ShowEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Width="420"
                            HorizontalAlignment="Center">
                    <TextBlock Text="{Binding EmptyStateTitle}"
                               Style="{StaticResource TitleTextStyle}"
                               TextAlignment="Center"/>
                    <TextBlock Text="{Binding EmptyStateMessage}"
                               Style="{StaticResource SubtitleTextStyle}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0"/>
                    <Button Content="Import Tracks"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding ImportTracksCommand}"
                            Margin="0,20,0,0"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Recent Tracks -->
            <StackPanel Margin="32,0,32,32"
                        Visibility="{Binding HasRecentTracks, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Recently Played"
                           Style="{StaticResource TitleTextStyle}"
                           Margin="0,0,0,16"/>
                <ItemsControl ItemsSource="{Binding RecentTracks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:TrackRowControl Title="{Binding Title}"
                                                      Artist="{Binding ArtistName}"
                                                      Album="{Binding AlbumTitle}"
                                                      Duration="{Binding DurationFormatted}"
                                                      CoverArtUrl="{Binding CoverArtUrl}"
                                                      Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"
                                                      Margin="0,0,0,8"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Recent Albums -->
            <StackPanel Margin="32,0,32,32"
                        Visibility="{Binding HasRecentAlbums, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="New Releases"
                           Style="{StaticResource TitleTextStyle}"
                           Margin="0,0,0,16"/>

                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal">
                        <ItemsControl ItemsSource="{Binding RecentAlbums}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:AlbumCard Title="{Binding Title}"
                                                        Artist="{Binding ArtistName}"
                                                        CoverArtUrl="{Binding CoverArtUrl}"
                                                        Year="{Binding ReleaseYear}"
                                                        Command="{Binding DataContext.NavigateToAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Id}"
                                                        Margin="0,0,16,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>

            <!-- Recent Artists -->
            <StackPanel Margin="32,0,32,32"
                        Visibility="{Binding HasRecentArtists, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Your Artists"
                           Style="{StaticResource TitleTextStyle}"
                           Margin="0,0,0,16"/>

                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal">
                        <ItemsControl ItemsSource="{Binding RecentArtists}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:ArtistCircleCard ArtistName="{Binding Name}"
                                                               ImageUrl="{Binding ImageUrl}"
                                                               Command="{Binding DataContext.NavigateToArtistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                               CommandParameter="{Binding Id}"
                                                               Margin="0,0,16,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
