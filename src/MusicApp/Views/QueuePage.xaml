<UserControl x:Class="MusicApp.Views.QueuePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MusicApp.Controls"
             Background="Transparent">

    <ScrollViewer Style="{StaticResource ScrollViewerStyle}"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,36">
            <Border Style="{StaticResource HeroSurfaceCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="QUEUE" Style="{StaticResource SectionEyebrowTextStyle}"/>
                        <TextBlock Text="Playback order stays visible, editable, and explainable."
                                   Style="{StaticResource HeroTextStyle}"
                                   FontSize="38"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding QueueSummary}"
                                   Style="{StaticResource SubtitleTextStyle}"
                                   Margin="0,12,0,0"/>
                        <TextBlock Text="{Binding SmartQueueStatusSummary}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"/>

                        <WrapPanel Margin="0,20,0,0">
                            <CheckBox Content="Enable Smart Queue"
                                      Style="{StaticResource CheckBoxStyle}"
                                      IsChecked="{Binding SmartQueueEnabled}"
                                      Margin="0,6,18,0"/>
                            <Button Content="Clear Queue"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding ClearQueueCommand}"
                                    Margin="0,0,10,10"/>
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{Binding UpNextItems.Count}" Style="{StaticResource MetricValueTextStyle}"/>
                                <TextBlock Text="Up Next" Style="{StaticResource MetricLabelTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding RecommendedItems.Count}" Style="{StaticResource MetricValueTextStyle}"/>
                                <TextBlock Text="Smart Inserts" Style="{StaticResource MetricLabelTextStyle}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource SurfaceCardStyle}"
                    Margin="0,20,0,0"
                    Visibility="{Binding CurrentItem, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Now Playing" Style="{StaticResource DisplaySectionTextStyle}"/>
                        <TextBlock Text="{Binding CurrentItem.Track.Title}"
                                   Style="{StaticResource TitleTextStyle}"
                                   Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding CurrentItem.Track.ArtistName}"
                                   Style="{StaticResource SubtitleTextStyle}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Style="{StaticResource InsetSurfaceCardStyle}"
                            Margin="18,0,0,0"
                            Visibility="{Binding CurrentItem.RecommendationReason, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Why It Is Here" Style="{StaticResource MetricLabelTextStyle}"/>
                            <TextBlock Text="{Binding CurrentItem.RecommendationReason}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,10,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource SurfaceCardStyle}"
                    Margin="0,20,0,0"
                    Visibility="{Binding HasQueueItems, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}">
                <StackPanel Width="540" HorizontalAlignment="Center">
                    <TextBlock Text="The queue is empty."
                               Style="{StaticResource TitleTextStyle}"
                               TextAlignment="Center"/>
                    <TextBlock Text="Start playback from Home, Search, My Wave, an artist, an album, or a playlist to build a real queue with visible ordering."
                               Style="{StaticResource SubtitleTextStyle}"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <Grid Margin="0,20,0,0"
                  Visibility="{Binding HasQueueItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.8*"/>
                    <ColumnDefinition Width="1.1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Up Next" Style="{StaticResource DisplaySectionTextStyle}"/>
                        <TextBlock Text="{Binding UpNextSummary}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,4,0,14"/>

                        <ItemsControl ItemsSource="{Binding UpNextItems}"
                                      Visibility="{Binding HasUpNextItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <controls:TrackRowControl Grid.Column="0"
                                                                  Title="{Binding Track.Title}"
                                                                  Artist="{Binding Track.ArtistName}"
                                                                  Album="{Binding Track.AlbumTitle}"
                                                                  Duration="{Binding Track.DurationFormatted}"
                                                                  CoverArtUrl="{Binding Track.CoverArtUrl}"
                                                                  IsPlaying="{Binding IsPlaying}"
                                                                  Command="{Binding DataContext.PlayItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  CommandParameter="{Binding}"/>
                                        <WrapPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <Button Content="Up"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,6,6"/>
                                            <Button Content="Down"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,6,6"/>
                                            <Button Content="Remove"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,0,6"/>
                                        </WrapPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="No explicit queued items remain."
                                   Style="{StaticResource SubtitleTextStyle}"
                                   Visibility="{Binding HasUpNextItems, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Margin="18,0,0,0">
                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Smart Queue" Style="{StaticResource DisplaySectionTextStyle}"/>
                            <TextBlock Text="{Binding RecommendationSummary}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,4,0,14"
                                       TextWrapping="Wrap"/>

                            <ItemsControl ItemsSource="{Binding RecommendedItems}"
                                          Visibility="{Binding HasRecommendedItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource InsetSurfaceCardStyle}" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Track.Title}" Style="{StaticResource BodyTextStyle}"/>
                                                <TextBlock Text="{Binding Track.ArtistName}" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0"/>
                                                <TextBlock Text="{Binding RecommendationReason}" Style="{StaticResource SmallCaptionTextStyle}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="No smart inserts are staged right now."
                                       Style="{StaticResource SubtitleTextStyle}"
                                       Visibility="{Binding HasRecommendedItems, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
