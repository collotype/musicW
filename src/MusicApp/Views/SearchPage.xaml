<UserControl x:Class="MusicApp.Views.SearchPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MusicApp.Controls"
             Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <ScrollViewer Style="{StaticResource ScrollViewerStyle}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Search Header -->
                <StackPanel Margin="32,32,32,0">
                    <TextBlock Text="Search"
                               Style="{StaticResource HeroTextStyle}"
                               Margin="0,0,0,24"/>

                    <!-- Search Box -->
                    <Grid>
                        <TextBox Style="{StaticResource SearchBoxStyle}"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,100,0"/>
                        <Button Content="Clear"
                                Style="{StaticResource GhostButtonStyle}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Command="{Binding ClearSearchCommand}"
                                Visibility="{Binding SearchQuery, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=invert}"/>
                    </Grid>

                    <!-- Filter Chips -->
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <RadioButton Content="All"
                                     Style="{StaticResource FilterChipStyle}"
                                     IsChecked="{Binding SelectedFilter, Converter={StaticResource EnumMatchConverter}, ConverterParameter=All}"
                                     Margin="0,0,8,8"/>
                        <RadioButton Content="Local"
                                     Style="{StaticResource FilterChipStyle}"
                                     IsChecked="{Binding SelectedFilter, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Local}"
                                     Margin="0,0,8,8"/>
                        <RadioButton Content="SoundCloud"
                                     Style="{StaticResource FilterChipStyle}"
                                     IsChecked="{Binding SelectedFilter, Converter={StaticResource EnumMatchConverter}, ConverterParameter=SoundCloud}"
                                     Margin="0,0,8,8"/>
                        <RadioButton Content="Spotify"
                                     Style="{StaticResource FilterChipStyle}"
                                     IsChecked="{Binding SelectedFilter, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Spotify}"
                                     Margin="0,0,8,8"/>
                    </StackPanel>
                </StackPanel>

                <!-- Search Results -->
                <StackPanel Margin="32,24,32,32"
                            Visibility="{Binding HasSearched, Converter={StaticResource BooleanToVisibilityConverter}}">

                    <!-- Loading State -->
                    <StackPanel HorizontalAlignment="Center"
                                Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Searching..."
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="16"/>
                    </StackPanel>

                    <!-- Error State -->
                    <StackPanel HorizontalAlignment="Center"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource ErrorBrush}"
                                   FontSize="16"/>
                    </StackPanel>

                    <!-- Results Content -->
                    <StackPanel Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}">

                        <!-- Tracks Section -->
                        <StackPanel Margin="0,0,0,32"
                                    Visibility="{Binding Results.Tracks.Count, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="Tracks"
                                       Style="{StaticResource TitleTextStyle}"
                                       Margin="0,0,0,16"/>
                            <ItemsControl ItemsSource="{Binding Results.Tracks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <controls:TrackRowControl Title="{Binding Title}"
                                                                  Artist="{Binding ArtistName}"
                                                                  Album="{Binding AlbumTitle}"
                                                                  Duration="{Binding DurationFormatted}"
                                                                  CoverArtUrl="{Binding CoverArtUrl}"
                                                                  Margin="0,0,0,8"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Artists Section -->
                        <StackPanel Margin="0,0,0,32"
                                    Visibility="{Binding Results.Artists.Count, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="Artists"
                                       Style="{StaticResource TitleTextStyle}"
                                       Margin="0,0,0,16"/>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                                <StackPanel Orientation="Horizontal">
                                    <ItemsControl ItemsSource="{Binding Results.Artists}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <controls:ArtistCircleCard ArtistName="{Binding Name}"
                                                                           ImageUrl="{Binding ImageUrl}"
                                                                           Margin="0,0,16,0"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>

                        <!-- Albums Section -->
                        <StackPanel Margin="0,0,0,32"
                                    Visibility="{Binding Results.Albums.Count, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="Albums"
                                       Style="{StaticResource TitleTextStyle}"
                                       Margin="0,0,0,16"/>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                                <StackPanel Orientation="Horizontal">
                                    <ItemsControl ItemsSource="{Binding Results.Albums}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <controls:AlbumCard Title="{Binding Title}"
                                                                    Artist="{Binding ArtistName}"
                                                                    CoverArtUrl="{Binding CoverArtUrl}"
                                                                    Year="{Binding ReleaseYear}"
                                                                    Margin="0,0,16,0"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>

                        <!-- Playlists Section -->
                        <StackPanel Margin="0,0,0,32"
                                    Visibility="{Binding Results.Playlists.Count, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="Playlists"
                                       Style="{StaticResource TitleTextStyle}"
                                       Margin="0,0,0,16"/>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                                <StackPanel Orientation="Horizontal">
                                    <ItemsControl ItemsSource="{Binding Results.Playlists}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <controls:PlaylistCard Title="{Binding Title}"
                                                                       Subtitle="{Binding OwnerName}"
                                                                       CoverArtUrl="{Binding CoverArtUrl}"
                                                                       Margin="0,0,16,0"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Empty State -->
                <StackPanel HorizontalAlignment="Center"
                            Margin="0,100,0,0"
                            Visibility="{Binding HasSearched, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}">
                    <TextBlock Text="🔍"
                               FontSize="64"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TertiaryTextBrush}"/>
                    <TextBlock Text="Search for music, artists, albums, or playlists"
                               Style="{StaticResource SubtitleTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
