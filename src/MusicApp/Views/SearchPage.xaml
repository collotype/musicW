<UserControl x:Class="MusicApp.Views.SearchPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MusicApp.Controls"
             Background="Transparent">

    <ScrollViewer Style="{StaticResource ScrollViewerStyle}"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,36">
            <TextBlock Text="Search"
                       Style="{StaticResource HeroTextStyle}"/>
            <TextBlock Text="Local library and connected providers stay inside the desktop app."
                       Style="{StaticResource SubtitleTextStyle}"
                       Margin="0,10,0,0"/>

            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <TextBox Style="{StaticResource SearchBoxStyle}"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="⌕"
                               FontSize="16"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Margin="16,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                </Grid>
                <ComboBox Grid.Column="1"
                          Margin="12,0,0,0"
                          Style="{StaticResource ComboBoxStyle}"
                          ItemsSource="{Binding AvailablePlaylists}"
                          DisplayMemberPath="Title"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SelectedPlaylistId, Mode=TwoWay}"/>
            </Grid>

            <WrapPanel Margin="0,18,0,0">
                <RadioButton Content="Tracks"
                             Style="{StaticResource FilterChipStyle}"
                             IsChecked="{Binding SelectedTab, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Tracks}"/>
                <RadioButton Content="Artists"
                             Style="{StaticResource FilterChipStyle}"
                             IsChecked="{Binding SelectedTab, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Artists}"/>
                <RadioButton Content="Albums"
                             Style="{StaticResource FilterChipStyle}"
                             IsChecked="{Binding SelectedTab, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Albums}"/>
                <RadioButton Content="Playlists"
                             Style="{StaticResource FilterChipStyle}"
                             IsChecked="{Binding SelectedTab, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Playlists}"/>
            </WrapPanel>

            <Border Style="{StaticResource SurfaceCardStyle}"
                    Margin="0,20,0,0"
                    Visibility="{Binding HasSearched, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}">
                <StackPanel Width="520" HorizontalAlignment="Center">
                    <TextBlock Text="Search is ready for local and provider-backed results."
                               Style="{StaticResource TitleTextStyle}"
                               TextAlignment="Center"/>
                    <TextBlock Text="Enter at least two characters to search tracks, artists, albums, and playlists without leaving the desktop workspace."
                               Style="{StaticResource SubtitleTextStyle}"
                               Margin="0,12,0,0"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SurfaceCardStyle}"
                    Margin="0,20,0,0"
                    Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Searching..."
                           Style="{StaticResource SubtitleTextStyle}"/>
            </Border>

            <Border Style="{StaticResource SurfaceCardStyle}"
                    Margin="0,20,0,0"
                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorBrush}"
                           TextWrapping="Wrap"/>
            </Border>

            <Border Style="{StaticResource SurfaceCardStyle}"
                    Margin="0,20,0,0"
                    Visibility="{Binding HasNoResults, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Width="520" HorizontalAlignment="Center">
                    <TextBlock Text="No results found"
                               Style="{StaticResource TitleTextStyle}"
                               TextAlignment="Center"/>
                    <TextBlock Text="Try another phrase or rely on local imports if the provider catalog is sparse."
                               Style="{StaticResource SubtitleTextStyle}"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Margin="0,22,0,0"
                        Visibility="{Binding HasTrackResults, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Visibility="{Binding SelectedTab, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Tracks}">
                    <TextBlock Text="Tracks"
                               Style="{StaticResource TitleTextStyle}"/>
                    <TextBlock Text="Play, queue, like, or send into a playlist directly from search."
                               Style="{StaticResource CaptionTextStyle}"
                               Margin="0,4,0,14"/>

                    <TextBlock Text="Local"
                               Style="{StaticResource LabelTextStyle}"
                               Visibility="{Binding LocalResults.Tracks, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <ItemsControl ItemsSource="{Binding LocalResults.Tracks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <controls:TrackRowControl Grid.Column="0"
                                                              Title="{Binding Title}"
                                                              Artist="{Binding ArtistName}"
                                                              Album="{Binding AlbumTitle}"
                                                              Duration="{Binding DurationFormatted}"
                                                              CoverArtUrl="{Binding CoverArtUrl}"
                                                              Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              CommandParameter="{Binding}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <Button Content="Queue"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Command="{Binding DataContext.QueueTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Margin="0,0,6,0"/>
                                        <Button Content="Like"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Command="{Binding DataContext.ToggleLikeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Margin="0,0,6,0"/>
                                        <Button Content="Add"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding DataContext.AddTrackToSelectedPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Online"
                               Style="{StaticResource LabelTextStyle}"
                               Margin="0,18,0,0"
                               Visibility="{Binding OnlineResults.Tracks, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <ItemsControl ItemsSource="{Binding OnlineResults.Tracks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <controls:TrackRowControl Grid.Column="0"
                                                              Title="{Binding Title}"
                                                              Artist="{Binding ArtistName}"
                                                              Album="{Binding AlbumTitle}"
                                                              Duration="{Binding DurationFormatted}"
                                                              CoverArtUrl="{Binding CoverArtUrl}"
                                                              Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              CommandParameter="{Binding}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <Button Content="Queue"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Command="{Binding DataContext.QueueTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Margin="0,0,6,0"/>
                                        <Button Content="Add"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding DataContext.AddTrackToSelectedPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>

            <StackPanel Margin="0,22,0,0"
                        Visibility="{Binding SelectedTab, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Artists}">
                <TextBlock Text="Artists"
                           Style="{StaticResource TitleTextStyle}"/>
                <TextBlock Text="Open full artist surfaces without leaving search."
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,4,0,14"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding LocalResults.Artists}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:ArtistCircleCard ArtistName="{Binding Name}"
                                                           ImageUrl="{Binding ImageUrl}"
                                                           Command="{Binding DataContext.NavigateToArtistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                           CommandParameter="{Binding Id}"
                                                           Margin="0,0,14,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Margin="0,16,0,0">
                    <ItemsControl ItemsSource="{Binding OnlineResults.Artists}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:ArtistCircleCard ArtistName="{Binding Name}"
                                                           ImageUrl="{Binding ImageUrl}"
                                                           Command="{Binding DataContext.NavigateToArtistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                           CommandParameter="{Binding Id}"
                                                           Margin="0,0,14,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <StackPanel Margin="0,22,0,0"
                        Visibility="{Binding SelectedTab, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Albums}">
                <TextBlock Text="Albums"
                           Style="{StaticResource TitleTextStyle}"/>
                <TextBlock Text="Artwork-first browsing with direct album surfaces."
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,4,0,14"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding LocalResults.Albums}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:AlbumCard Title="{Binding Title}"
                                                    Artist="{Binding ArtistName}"
                                                    CoverArtUrl="{Binding CoverArtUrl}"
                                                    Year="{Binding ReleaseYear}"
                                                    Command="{Binding DataContext.NavigateToAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    Margin="0,0,14,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Margin="0,16,0,0">
                    <ItemsControl ItemsSource="{Binding OnlineResults.Albums}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:AlbumCard Title="{Binding Title}"
                                                    Artist="{Binding ArtistName}"
                                                    CoverArtUrl="{Binding CoverArtUrl}"
                                                    Year="{Binding ReleaseYear}"
                                                    Command="{Binding DataContext.NavigateToAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    Margin="0,0,14,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <StackPanel Margin="0,22,0,0"
                        Visibility="{Binding SelectedTab, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Playlists}">
                <TextBlock Text="Playlists"
                           Style="{StaticResource TitleTextStyle}"/>
                <TextBlock Text="Collections from your library and connected providers."
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,4,0,14"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding LocalResults.Playlists}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:PlaylistCard Title="{Binding Title}"
                                                       Subtitle="{Binding OwnerName}"
                                                       CoverArtUrl="{Binding CoverArtUrl}"
                                                       Command="{Binding DataContext.NavigateToPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       CommandParameter="{Binding Id}"
                                                       Margin="0,0,14,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Margin="0,16,0,0">
                    <ItemsControl ItemsSource="{Binding OnlineResults.Playlists}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:PlaylistCard Title="{Binding Title}"
                                                       Subtitle="{Binding OwnerName}"
                                                       CoverArtUrl="{Binding CoverArtUrl}"
                                                       Command="{Binding DataContext.NavigateToPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       CommandParameter="{Binding Id}"
                                                       Margin="0,0,14,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
