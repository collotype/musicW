<UserControl x:Class="MusicApp.Views.AlbumPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MusicApp.Controls"
             Background="Transparent">

    <Grid>
        <ScrollViewer Style="{StaticResource ScrollViewerStyle}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,24,28,36">
                <Border Style="{StaticResource SurfaceCardStyle}"
                        Background="{StaticResource HeroGradientBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Width="240"
                                Height="240"
                                CornerRadius="24">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding Album.CoverArtUrl}" Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="30,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="ALBUM"
                                       Style="{StaticResource SectionEyebrowTextStyle}"/>
                            <TextBlock Text="{Binding Album.Title}"
                                       Style="{StaticResource HeroTextStyle}"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Album.ArtistName}"
                                       Style="{StaticResource SubtitleTextStyle}"
                                       Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding Album.ReleaseYear}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding Album.TotalDurationFormatted}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,4,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,22,0,0">
                                <Button Content="Play"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding PlayAllCommand}"
                                        Margin="0,0,10,0"/>
                                <Button Content="Shuffle"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding ShuffleCommand}"
                                        Margin="0,0,10,0"/>
                                <Button Content="Start Wave"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding StartWaveCommand}"
                                        Margin="0,0,10,0"/>
                                <Button Content="Save Album"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding ToggleSaveAlbumCommand}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                <ComboBox Width="220"
                                          Style="{StaticResource ComboBoxStyle}"
                                          ItemsSource="{Binding AvailablePlaylists}"
                                          DisplayMemberPath="Title"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding SelectedPlaylistId, Mode=TwoWay}"/>
                                <Button Content="Add Album to Playlist"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding AddAlbumToSelectedPlaylistCommand}"
                                        Margin="10,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock Text="Tracklist"
                           Style="{StaticResource TitleTextStyle}"
                           Margin="0,22,0,0"/>
                <ItemsControl ItemsSource="{Binding Album.Tracks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:TrackRowControl Title="{Binding Title}"
                                                      Artist="{Binding ArtistName}"
                                                      Album="{Binding AlbumTitle}"
                                                      Duration="{Binding DurationFormatted}"
                                                      CoverArtUrl="{Binding CoverArtUrl}"
                                                      TrackNumber="{Binding TrackNumber}"
                                                      Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"
                                                      Margin="0,0,0,8"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Related Releases"
                           Style="{StaticResource TitleTextStyle}"
                           Margin="0,24,0,0"
                           Visibility="{Binding HasRelatedReleases, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Margin="0,12,0,0"
                              Visibility="{Binding HasRelatedReleases, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding RelatedReleases}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:AlbumCard Title="{Binding Title}"
                                                    Artist="{Binding ArtistName}"
                                                    CoverArtUrl="{Binding CoverArtUrl}"
                                                    Year="{Binding ReleaseYear}"
                                                    Command="{Binding DataContext.NavigateToRelatedAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    Margin="0,0,14,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </ScrollViewer>

        <Border Background="#A0101318"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="Loading album..."
                       Style="{StaticResource SubtitleTextStyle}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <Border Background="#A0101318"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource ErrorBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
