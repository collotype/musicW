<UserControl x:Class="MusicApp.Views.AlbumPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MusicApp.Controls"
             Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <ScrollViewer Style="{StaticResource ScrollViewerStyle}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Hero Header -->
                <Border Height="400">
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding Album.CoverArtUrl}" Stretch="UniformToFill"/>
                    </Border.Background>
                    <Border.Effect>
                        <BlurEffect Radius="60"/>
                    </Border.Effect>
                </Border>

                <Grid Margin="32,-360,32,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Album Cover -->
                    <Border Grid.Column="0"
                            CornerRadius="12"
                            Width="240"
                            Height="240"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding Album.CoverArtUrl}" Stretch="UniformToFill"/>
                        </Border.Background>
                        <Border x:Name="coverPlaceholder"
                                Background="{StaticResource BorderLightBrush}"
                                CornerRadius="12">
                            <TextBlock Text="💿"
                                       FontSize="80"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                        </Border>
                    </Border>

                    <!-- Album Info -->
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Bottom"
                                Margin="32,0,0,0">
                        <TextBlock Text="ALBUM"
                                   Style="{StaticResource LabelTextStyle}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Album.Title, FallbackValue='Album Title'}"
                                   Style="{StaticResource HeroTextStyle}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding Album.ArtistName, FallbackValue='Artist Name'}"
                                   Style="{StaticResource SubtitleTextStyle}"
                                   Margin="0,8,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <TextBlock Text="{Binding Album.ReleaseYear, FallbackValue='2024'}"
                                       Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text=" • "
                                       Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text="{Binding Album.TotalTracks, FallbackValue='0'}"
                                       Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text=" tracks"
                                       Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text=" • "
                                       Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text="{Binding Album.TotalDurationFormatted, FallbackValue='0:00'}"
                                       Style="{StaticResource CaptionTextStyle}"/>
                        </StackPanel>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                            <Button Content="Play All"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding PlayAllCommand}"
                                    Margin="0,0,12,0"/>
                            <Button Content="Shuffle"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,12,0"/>
                            <controls:FavoriteButton IsChecked="{Binding Album.IsLiked, Mode=TwoWay}"
                                                     Width="40"
                                                     Height="40"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Track List -->
                <StackPanel Margin="0,0,0,32">
                    <ItemsControl ItemsSource="{Binding Album.Tracks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:TrackRowControl Title="{Binding Title}"
                                                          Artist="{Binding ArtistName}"
                                                          Album="{Binding AlbumTitle}"
                                                          Duration="{Binding DurationFormatted}"
                                                          CoverArtUrl="{Binding CoverArtUrl}"
                                                          TrackNumber="{Binding TrackNumber}"
                                                          IsLiked="{Binding IsLiked}"
                                                          Margin="32,0,32,8"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Background="{StaticResource AppBackgroundBrush}"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Loading..."
                           Foreground="{StaticResource SecondaryTextBrush}"
                           FontSize="16"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
