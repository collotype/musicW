<UserControl x:Class="MusicApp.Views.ArtistPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MusicApp.Controls"
             Background="Transparent">

    <Grid>
        <ScrollViewer Style="{StaticResource ScrollViewerStyle}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,24,28,36">
                <Border Style="{StaticResource HeroSurfaceCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="230"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="210"
                                Height="210"
                                CornerRadius="28">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding Artist.ImageUrl}" Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="26,0,20,0" VerticalAlignment="Center">
                            <TextBlock Text="ARTIST" Style="{StaticResource SectionEyebrowTextStyle}"/>
                            <TextBlock Text="{Binding Artist.Name}"
                                       Style="{StaticResource HeroTextStyle}"
                                       FontSize="40"
                                       Margin="0,10,0,0"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding HeaderSummary}"
                                       Style="{StaticResource SubtitleTextStyle}"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Artist.Biography}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding HasBiography, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                            <WrapPanel Margin="0,20,0,0">
                                <Button Content="Play Artist"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding PlayAllCommand}"
                                        Margin="0,0,10,10"/>
                                <Button Content="Shuffle"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding ShuffleCommand}"
                                        Margin="0,0,10,10"/>
                                <Button Content="Start Wave"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding StartWaveCommand}"
                                        Margin="0,0,10,10"/>
                                <Button Content="Favorite"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding ToggleFavoriteArtistCommand}"
                                        Margin="0,0,0,10"/>
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="{Binding SourceLabel}" Style="{StaticResource MetricValueTextStyle}" FontSize="26"/>
                                    <TextBlock Text="Source" Style="{StaticResource MetricLabelTextStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding TrackSummary}" Style="{StaticResource BodyTextStyle}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding ReleaseSummary}" Style="{StaticResource SmallCaptionTextStyle}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <WrapPanel Margin="0,16,0,0"
                           Visibility="{Binding HasGenres, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding Artist.Genres}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource BadgeBorderStyle}" Margin="0,0,10,10">
                                    <TextBlock Text="{Binding}" Style="{StaticResource SmallCaptionTextStyle}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </WrapPanel>

                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.7*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SurfaceCardStyle}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="250"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Popular Tracks" Style="{StaticResource DisplaySectionTextStyle}"/>
                                    <TextBlock Text="Play, open album context, or add tracks into playlists without leaving the artist surface."
                                               Style="{StaticResource CaptionTextStyle}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <ComboBox Grid.Column="1"
                                          Style="{StaticResource ComboBoxStyle}"
                                          ItemsSource="{Binding AvailablePlaylists}"
                                          DisplayMemberPath="Title"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding SelectedPlaylistId, Mode=TwoWay}"/>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding TopTracks}" Margin="0,14,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <controls:TrackRowControl Grid.Column="0"
                                                                      Title="{Binding Title}"
                                                                      Artist="{Binding ArtistName}"
                                                                      Album="{Binding AlbumTitle}"
                                                                      Duration="{Binding DurationFormatted}"
                                                                      CoverArtUrl="{Binding CoverArtUrl}"
                                                                      Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      CommandParameter="{Binding}"/>
                                            <WrapPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <Button Content="Album"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Command="{Binding DataContext.NavigateToAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding AlbumId}"
                                                        Margin="0,0,6,6"/>
                                                <Button Content="Add"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Command="{Binding DataContext.AddTrackToSelectedPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Margin="0,0,0,6"/>
                                            </WrapPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="18,0,0,0">
                        <Border Style="{StaticResource SurfaceCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Releases" Style="{StaticResource DisplaySectionTextStyle}"/>
                                <TextBlock Text="{Binding ReleaseSummary}"
                                           Style="{StaticResource CaptionTextStyle}"
                                           Margin="0,4,0,14"
                                           TextWrapping="Wrap"/>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled"
                                              Visibility="{Binding HasAlbums, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ItemsControl ItemsSource="{Binding Albums}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <controls:AlbumCard Title="{Binding Title}"
                                                                    Artist="{Binding ArtistName}"
                                                                    CoverArtUrl="{Binding CoverArtUrl}"
                                                                    Year="{Binding ReleaseYear}"
                                                                    Command="{Binding DataContext.NavigateToAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding Id}"
                                                                    Margin="0,0,14,0"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="Related Artists" Style="{StaticResource DisplaySectionTextStyle}"/>
                                <TextBlock Text="Genre-adjacent artists from the indexed library."
                                           Style="{StaticResource CaptionTextStyle}"
                                           Margin="0,4,0,14"/>
                                <ItemsControl ItemsSource="{Binding RelatedArtists}"
                                              Visibility="{Binding HasRelatedArtists, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <controls:ArtistCircleCard ArtistName="{Binding Name}"
                                                                       ImageUrl="{Binding ImageUrl}"
                                                                       Command="{Binding DataContext.NavigateToArtistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                       CommandParameter="{Binding Id}"
                                                                       Margin="0,0,14,14"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Border Background="#A0101318"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="Loading artist..."
                       Style="{StaticResource SubtitleTextStyle}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <Border Background="#A0101318"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource ErrorBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
