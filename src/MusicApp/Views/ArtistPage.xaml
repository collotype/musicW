<UserControl x:Class="MusicApp.Views.ArtistPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MusicApp.Controls"
             Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <ScrollViewer Style="{StaticResource ScrollViewerStyle}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <controls:HeroHeader Label="ARTIST"
                                     Title="{Binding Artist.Name, FallbackValue='Artist Name'}"
                                     Subtitle="{Binding Artist.MonthlyListenersFormatted, FallbackValue='Artist'}"
                                     ImageUrl="{Binding Artist.ImageUrl}"
                                     BackgroundImageUrl="{Binding Artist.BannerUrl}"
                                     Height="320"/>

                <StackPanel Orientation="Horizontal" Margin="32,24,32,0">
                    <Button Content="Play All"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding PlayAllCommand}"
                            Margin="0,0,12,0"/>
                    <Button Content="Shuffle"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ShuffleCommand}"/>
                </StackPanel>

                <WrapPanel Margin="32,16,32,0"
                           Visibility="{Binding HasGenres, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding Artist.Genres}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:TagChip Text="{Binding}" Margin="0,0,8,8"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </WrapPanel>

                <StackPanel Margin="0,32,0,0"
                            Visibility="{Binding HasTopTracks, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Popular Tracks"
                               Style="{StaticResource TitleTextStyle}"
                               Margin="32,0,32,16"/>

                    <ItemsControl ItemsSource="{Binding TopTracks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:TrackRowControl Title="{Binding Title}"
                                                          Artist="{Binding ArtistName}"
                                                          Duration="{Binding DurationFormatted}"
                                                          CoverArtUrl="{Binding CoverArtUrl}"
                                                          IsLiked="{Binding IsLiked}"
                                                          Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"
                                                          Margin="32,0,32,8"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Margin="0,32,0,0"
                            Visibility="{Binding HasAlbums, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Discography"
                               Style="{StaticResource TitleTextStyle}"
                               Margin="32,0,32,16"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Padding="32,0">
                        <StackPanel Orientation="Horizontal">
                            <ItemsControl ItemsSource="{Binding Albums}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <controls:AlbumCard Title="{Binding Title}"
                                                            Artist="{Binding ArtistName}"
                                                            CoverArtUrl="{Binding CoverArtUrl}"
                                                            Year="{Binding ReleaseYear}"
                                                            Command="{Binding DataContext.NavigateToAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding Id}"
                                                            Margin="0,0,16,0"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>

                <StackPanel Margin="0,32,0,32"
                            Visibility="{Binding HasRelatedArtists, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Related Artists"
                               Style="{StaticResource TitleTextStyle}"
                               Margin="32,0,32,16"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Padding="32,0">
                        <StackPanel Orientation="Horizontal">
                            <ItemsControl ItemsSource="{Binding RelatedArtists}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <controls:ArtistCircleCard ArtistName="{Binding Name}"
                                                                   ImageUrl="{Binding ImageUrl}"
                                                                   Command="{Binding DataContext.NavigateToArtistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                   CommandParameter="{Binding Id}"
                                                                   Margin="0,0,16,0"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Background="{StaticResource AppBackgroundBrush}"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Loading..."
                           Foreground="{StaticResource SecondaryTextBrush}"
                           FontSize="16"/>
            </StackPanel>
        </Border>

        <Border Background="{StaticResource AppBackgroundBrush}"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorBrush}"
                           FontSize="16"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
