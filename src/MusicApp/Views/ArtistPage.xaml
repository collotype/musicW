<UserControl x:Class="MusicApp.Views.ArtistPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MusicApp.Controls"
             Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <ScrollViewer Style="{StaticResource ScrollViewerStyle}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Hero Header -->
                <controls:HeroHeader Label="ARTIST"
                                     Title="{Binding Artist.Name, FallbackValue='Artist Name'}"
                                     Subtitle="{Binding Artist.MonthlyListenersFormatted, FallbackValue='0 listeners'}"
                                     ImageUrl="{Binding Artist.ImageUrl}"
                                     BackgroundImageUrl="{Binding Artist.BannerUrl}"
                                     Height="320"/>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" Margin="32,24,32,0">
                    <Button Content="Play All"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding PlayAllCommand}"
                            Margin="0,0,12,0"/>
                    <Button Content="Shuffle"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,12,0"/>
                    <Button Content="{Binding Artist.IsFollowed, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue='Follow'}"
                            Style="{StaticResource GhostButtonStyle}"
                            Command="{Binding ToggleFollowCommand}"/>
                </StackPanel>

                <!-- Genre Tags -->
                <WrapPanel Margin="32,16,32,0">
                    <ItemsControl ItemsSource="{Binding Artist.Genres}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:TagChip Text="{Binding}" Margin="0,0,8,8"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </WrapPanel>

                <!-- Top Tracks Section -->
                <StackPanel Margin="0,32,0,0">
                    <TextBlock Text="Popular Tracks"
                               Style="{StaticResource TitleTextStyle}"
                               Margin="32,0,32,16"/>

                    <ItemsControl ItemsSource="{Binding TopTracks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:TrackRowControl Title="{Binding Title}"
                                                          Artist="{Binding ArtistName}"
                                                          Duration="{Binding DurationFormatted}"
                                                          CoverArtUrl="{Binding CoverArtUrl}"
                                                          IsLiked="{Binding IsLiked}"
                                                          Margin="32,0,32,8"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Albums Section -->
                <StackPanel Margin="0,32,0,0">
                    <Grid Margin="32,0,32,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Discography"
                                   Style="{StaticResource TitleTextStyle}"/>
                        <Button Grid.Column="1"
                                Content="Show all"
                                Style="{StaticResource GhostButtonStyle}"
                                VerticalAlignment="Center"/>
                    </Grid>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Padding="32,0">
                        <StackPanel Orientation="Horizontal">
                            <ItemsControl ItemsSource="{Binding Albums}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <controls:AlbumCard Title="{Binding Title}"
                                                            Artist="{Binding ArtistName}"
                                                            CoverArtUrl="{Binding CoverArtUrl}"
                                                            Year="{Binding ReleaseYear}"
                                                            Margin="0,0,16,0"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>

                <!-- Related Artists Section -->
                <StackPanel Margin="0,32,0,32">
                    <TextBlock Text="Related Artists"
                               Style="{StaticResource TitleTextStyle}"
                               Margin="32,0,32,16"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Padding="32,0">
                        <StackPanel Orientation="Horizontal">
                            <ItemsControl ItemsSource="{Binding RelatedArtists}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <controls:ArtistCircleCard ArtistName="{Binding Name}"
                                                                   ImageUrl="{Binding ImageUrl}"
                                                                   Margin="0,0,16,0"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Background="{StaticResource AppBackgroundBrush}"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Loading..."
                           Foreground="{StaticResource SecondaryTextBrush}"
                           FontSize="16"/>
            </StackPanel>
        </Border>

        <!-- Error Overlay -->
        <Border Background="{StaticResource AppBackgroundBrush}"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorBrush}"
                           FontSize="16"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
