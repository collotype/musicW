<UserControl x:Class="MusicApp.Views.ArtistPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MusicApp.Controls"
             Background="Transparent">

    <Grid>
        <ScrollViewer Style="{StaticResource ScrollViewerStyle}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,24,28,36">
                <Border Style="{StaticResource SurfaceCardStyle}"
                        Background="{StaticResource HeroGradientBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Width="200"
                                Height="200"
                                CornerRadius="20">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding Artist.ImageUrl}" Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="26,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="ARTIST"
                                       Style="{StaticResource SectionEyebrowTextStyle}"/>
                            <TextBlock Text="{Binding Artist.Name}"
                                       Style="{StaticResource HeroTextStyle}"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Artist.MonthlyListenersFormatted}"
                                       Style="{StaticResource SubtitleTextStyle}"
                                       Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding Artist.Biography}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding HasBiography, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                <Button Content="Play"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding PlayAllCommand}"
                                        Margin="0,0,10,0"/>
                                <Button Content="Shuffle"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding ShuffleCommand}"
                                        Margin="0,0,10,0"/>
                                <Button Content="Start Wave"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding StartWaveCommand}"
                                        Margin="0,0,10,0"/>
                                <Button Content="Favorite Artist"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding ToggleFavoriteArtistCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <WrapPanel Margin="0,16,0,0"
                           Visibility="{Binding HasGenres, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding Artist.Genres}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#12FFFFFF"
                                        BorderBrush="{StaticResource BorderSubtleBrush}"
                                        BorderThickness="1"
                                        CornerRadius="999"
                                        Padding="12,6"
                                        Margin="0,0,8,8">
                                    <TextBlock Text="{Binding}"
                                               Style="{StaticResource CaptionTextStyle}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </WrapPanel>

                <Grid Margin="0,22,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Popular Tracks"
                               Style="{StaticResource TitleTextStyle}"
                               Grid.Column="0"/>
                    <ComboBox Grid.Column="1"
                              Style="{StaticResource ComboBoxStyle}"
                              ItemsSource="{Binding AvailablePlaylists}"
                              DisplayMemberPath="Title"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding SelectedPlaylistId, Mode=TwoWay}"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding TopTracks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <controls:TrackRowControl Grid.Column="0"
                                                          Title="{Binding Title}"
                                                          Artist="{Binding ArtistName}"
                                                          Album="{Binding AlbumTitle}"
                                                          Duration="{Binding DurationFormatted}"
                                                          CoverArtUrl="{Binding CoverArtUrl}"
                                                          Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                <Button Grid.Column="1"
                                        Content="Add"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding DataContext.AddTrackToSelectedPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Releases"
                           Style="{StaticResource TitleTextStyle}"
                           Margin="0,24,0,0"
                           Visibility="{Binding HasAlbums, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Margin="0,12,0,0"
                              Visibility="{Binding HasAlbums, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding Albums}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:AlbumCard Title="{Binding Title}"
                                                    Artist="{Binding ArtistName}"
                                                    CoverArtUrl="{Binding CoverArtUrl}"
                                                    Year="{Binding ReleaseYear}"
                                                    Command="{Binding DataContext.NavigateToAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    Margin="0,0,14,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock Text="Related Artists"
                           Style="{StaticResource TitleTextStyle}"
                           Margin="0,24,0,0"
                           Visibility="{Binding HasRelatedArtists, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Margin="0,12,0,0"
                              Visibility="{Binding HasRelatedArtists, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding RelatedArtists}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:ArtistCircleCard ArtistName="{Binding Name}"
                                                           ImageUrl="{Binding ImageUrl}"
                                                           Command="{Binding DataContext.NavigateToArtistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                           CommandParameter="{Binding Id}"
                                                           Margin="0,0,14,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </ScrollViewer>

        <Border Background="#A0101318"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="Loading artist..."
                       Style="{StaticResource SubtitleTextStyle}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <Border Background="#A0101318"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource ErrorBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
