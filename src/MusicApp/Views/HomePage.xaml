<UserControl x:Class="MusicApp.Views.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MusicApp.Controls"
             Background="Transparent">

    <ScrollViewer Style="{StaticResource ScrollViewerStyle}"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,36">
            <Border Style="{StaticResource SurfaceCardStyle}"
                    Background="{StaticResource HeroGradientBrush}"
                    Padding="28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" MaxWidth="720">
                        <TextBlock Text="HOME"
                                   Style="{StaticResource SectionEyebrowTextStyle}"/>
                        <TextBlock Text="A desktop music workspace built for long sessions, not quick taps."
                                   Style="{StaticResource HeroTextStyle}"
                                   FontSize="42"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0"/>
                        <TextBlock Text="My Wave, discovery rows, playlists, and deep library actions live together here. When your local library grows, this surface adapts around it."
                                   Style="{StaticResource SubtitleTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,22,0,0">
                            <Button Content="Open My Wave"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding OpenMyWaveCommand}"
                                    Margin="0,0,10,0"/>
                            <Button Content="Search Music"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding OpenSearchCommand}"
                                    Margin="0,0,10,0"/>
                            <Button Content="Liked Tracks"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Command="{Binding OpenLikedTracksCommand}"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Width="280"
                            Height="220"
                            Margin="24,0,0,0"
                            CornerRadius="20"
                            Background="#18000000"
                            BorderBrush="{StaticResource BorderLightOpacityBrush}"
                            BorderThickness="1">
                        <StackPanel Margin="20">
                            <TextBlock Text="Quick Actions"
                                       Style="{StaticResource LabelTextStyle}"/>
                            <Button Content="Library Overview"
                                    Style="{StaticResource GhostButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Margin="0,14,0,0"
                                    Command="{Binding OpenLibraryCommand}"/>
                            <Button Content="Resume Session"
                                    Style="{StaticResource GhostButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Margin="0,6,0,0"
                                    Command="{Binding OpenLibraryCommand}"/>
                            <Separator Margin="0,14,0,14"
                                       Background="{StaticResource BorderLightBrush}"/>
                            <TextBlock Text="This build keeps empty states honest."
                                       Style="{StaticResource BodyTextStyle}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="If the library is sparse, discovery and wave surfaces explain what data they still need."
                                       Style="{StaticResource CaptionTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource SurfaceCardStyle}"
                    Margin="0,20,0,0"
                    Visibility="{Binding HasLibraryDrivenHome, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}">
                <StackPanel Width="520" HorizontalAlignment="Center">
                    <TextBlock Text="Home is ready. The library still needs more listening data."
                               Style="{StaticResource TitleTextStyle}"
                               TextAlignment="Center"/>
                    <TextBlock Text="Import local audio, like tracks, or play a few albums. My Wave, continue listening, favorite artists, and discovery rows will then become much richer."
                               Style="{StaticResource SubtitleTextStyle}"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                    <Button Content="Open Library"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding OpenLibraryCommand}"
                            Margin="0,18,0,0"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Margin="0,24,0,0"
                        Visibility="{Binding HasLibraryDrivenHome, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Continue Listening"
                           Style="{StaticResource TitleTextStyle}"/>
                <TextBlock Text="Fast return path into what you played recently."
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,4,0,14"/>
                <ItemsControl ItemsSource="{Binding ContinueListening}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:TrackRowControl Title="{Binding Title}"
                                                      Artist="{Binding ArtistName}"
                                                      Album="{Binding AlbumTitle}"
                                                      Duration="{Binding DurationFormatted}"
                                                      CoverArtUrl="{Binding CoverArtUrl}"
                                                      Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"
                                                      Margin="0,0,0,8"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Margin="0,28,0,0"
                        Visibility="{Binding HasFavoriteArtists, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Favorite Artists"
                           Style="{StaticResource TitleTextStyle}"/>
                <TextBlock Text="Followed and high-signal artists surface here."
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,4,0,14"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding FavoriteArtists}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:ArtistCircleCard ArtistName="{Binding Name}"
                                                           ImageUrl="{Binding ImageUrl}"
                                                           Command="{Binding DataContext.NavigateToArtistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                           CommandParameter="{Binding Id}"
                                                           Margin="0,0,14,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <StackPanel Margin="0,28,0,0"
                        Visibility="{Binding HasSuggestedAlbums, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Albums You May Like"
                           Style="{StaticResource TitleTextStyle}"/>
                <TextBlock Text="Weighted by favorites, recent listening, and what still deserves a front-row spot."
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,4,0,14"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding SuggestedAlbums}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:AlbumCard Title="{Binding Title}"
                                                    Artist="{Binding ArtistName}"
                                                    CoverArtUrl="{Binding CoverArtUrl}"
                                                    Year="{Binding ReleaseYear}"
                                                    Command="{Binding DataContext.NavigateToAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    Margin="0,0,14,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <StackPanel Margin="0,28,0,0"
                        Visibility="{Binding HasHighlightedPlaylists, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Playlists"
                           Style="{StaticResource TitleTextStyle}"/>
                <TextBlock Text="Pinned collections and recently maintained playlists."
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,4,0,14"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding HighlightedPlaylists}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:PlaylistCard Title="{Binding Title}"
                                                       Subtitle="{Binding OwnerName}"
                                                       CoverArtUrl="{Binding CoverArtUrl}"
                                                       Command="{Binding DataContext.NavigateToPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       CommandParameter="{Binding Id}"
                                                       Margin="0,0,14,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <Grid Margin="0,28,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                    <TextBlock Text="Discovery Lane"
                               Style="{StaticResource TitleTextStyle}"/>
                    <TextBlock Text="Tracks with the strongest home-screen fit right now."
                               Style="{StaticResource CaptionTextStyle}"
                               Margin="0,4,0,14"/>
                    <ItemsControl ItemsSource="{Binding DiscoveryTracks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:TrackRowControl Title="{Binding Title}"
                                                          Artist="{Binding ArtistName}"
                                                          Album="{Binding AlbumTitle}"
                                                          Duration="{Binding DurationFormatted}"
                                                          CoverArtUrl="{Binding CoverArtUrl}"
                                                          Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"
                                                          Margin="0,0,0,8"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <Border Grid.Column="1"
                        Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Snippet Preview"
                                   Style="{StaticResource TitleTextStyle}"
                                   FontSize="22"/>
                        <TextBlock Text="Short entry points into promising moments."
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,4,0,14"/>
                        <ItemsControl ItemsSource="{Binding SnippetMoments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="12"
                                            CornerRadius="14"
                                            Background="#10FFFFFF">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Track.Title}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Detail}"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <Button Content="Play Snippet"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Command="{Binding DataContext.PlaySnippetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding StartLabel}"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource CaptionTextStyle}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
