<UserControl x:Class="MusicApp.Views.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MusicApp.Controls"
             Background="Transparent">

    <ScrollViewer Style="{StaticResource ScrollViewerStyle}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,36">
            <Border Style="{StaticResource HeroSurfaceCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*"/>
                        <ColumnDefinition Width="1.2*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" MaxWidth="760">
                        <TextBlock Text="HOME" Style="{StaticResource SectionEyebrowTextStyle}"/>
                        <TextBlock Text="A dark desktop workspace for long listening sessions, deliberate discovery, and deep library control."
                                   Style="{StaticResource HeroTextStyle}"
                                   FontSize="44"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="My Wave, recent sessions, artists, albums, playlists, lyrics, queue control, and snippets all stay inside one shell instead of scattering into temporary popups."
                                   Style="{StaticResource SubtitleTextStyle}"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap"/>

                        <WrapPanel Margin="0,22,0,0">
                            <Button Content="Open My Wave" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding OpenMyWaveCommand}" Margin="0,0,10,10"/>
                            <Button Content="Search Music" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding OpenSearchCommand}" Margin="0,0,10,10"/>
                            <Button Content="Recent Sessions" Style="{StaticResource GhostButtonStyle}" Command="{Binding OpenRecentCommand}" Margin="0,0,10,10"/>
                            <Button Content="Downloads" Style="{StaticResource GhostButtonStyle}" Command="{Binding OpenDownloadsCommand}" Margin="0,0,10,10"/>
                        </WrapPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource InsetSurfaceCardStyle}" Margin="22,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Quick Actions" Style="{StaticResource MetricLabelTextStyle}"/>
                            <TextBlock Text="{Binding DiscoverySummary}" Style="{StaticResource BodyTextStyle}" Margin="0,10,0,0" TextWrapping="Wrap"/>
                            <Button Content="Library Overview" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding OpenLibraryCommand}" Margin="0,16,0,0"/>
                            <Button Content="Playlist Shelf" Style="{StaticResource GhostButtonStyle}" Command="{Binding OpenPlaylistsCommand}" Margin="0,8,0,0"/>
                            <Button Content="Liked Tracks" Style="{StaticResource GhostButtonStyle}" Command="{Binding OpenLikedTracksCommand}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <UniformGrid Columns="4" Margin="0,20,0,0">
                <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Continue" Style="{StaticResource MetricLabelTextStyle}"/>
                        <TextBlock Text="{Binding ContinueListening.Count}" Style="{StaticResource MetricValueTextStyle}" Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding ContinueListeningSummary}" Style="{StaticResource CaptionTextStyle}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Artists" Style="{StaticResource MetricLabelTextStyle}"/>
                        <TextBlock Text="{Binding FavoriteArtists.Count}" Style="{StaticResource MetricValueTextStyle}" Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding FavoriteArtistsSummary}" Style="{StaticResource CaptionTextStyle}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Albums" Style="{StaticResource MetricLabelTextStyle}"/>
                        <TextBlock Text="{Binding SuggestedAlbums.Count}" Style="{StaticResource MetricValueTextStyle}" Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding AlbumShelfSummary}" Style="{StaticResource CaptionTextStyle}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Playlists" Style="{StaticResource MetricLabelTextStyle}"/>
                        <TextBlock Text="{Binding HighlightedPlaylists.Count}" Style="{StaticResource MetricValueTextStyle}" Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding PlaylistShelfSummary}" Style="{StaticResource CaptionTextStyle}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Style="{StaticResource SurfaceCardStyle}"
                    Margin="0,20,0,0"
                    Visibility="{Binding HasLibraryDrivenHome, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}">
                <StackPanel Width="520" HorizontalAlignment="Center">
                    <TextBlock Text="Home is ready. The workspace just needs more listening signal."
                               Style="{StaticResource TitleTextStyle}"
                               TextAlignment="Center"/>
                    <TextBlock Text="Import local audio, like a few tracks, or finish a couple of listening sessions. The discovery rows, artist shelf, and My Wave tuner will then become much stronger."
                               Style="{StaticResource SubtitleTextStyle}"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                    <Button Content="Open Library" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding OpenLibraryCommand}" HorizontalAlignment="Center" Margin="0,18,0,0"/>
                </StackPanel>
            </Border>

            <Grid Margin="0,24,0,0" Visibility="{Binding HasLibraryDrivenHome, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.15*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Continue Listening" Style="{StaticResource DisplaySectionTextStyle}"/>
                            <TextBlock Text="{Binding ContinueListeningSummary}" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,14"/>
                            <ItemsControl ItemsSource="{Binding ContinueListening}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <controls:TrackRowControl Grid.Column="0"
                                                                      Title="{Binding Title}"
                                                                      Artist="{Binding ArtistName}"
                                                                      Album="{Binding AlbumTitle}"
                                                                      Duration="{Binding DurationFormatted}"
                                                                      CoverArtUrl="{Binding CoverArtUrl}"
                                                                      Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      CommandParameter="{Binding}"/>
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    Command="{Binding DataContext.StartWaveFromTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="10,0,0,0">
                                                <TextBlock Text="Wave"/>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,18,0,0" Visibility="{Binding HasDiscoveryTracks, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Discovery Lane" Style="{StaticResource DisplaySectionTextStyle}"/>
                            <TextBlock Text="{Binding DiscoverySummary}" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,14"/>
                            <ItemsControl ItemsSource="{Binding DiscoveryTracks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <controls:TrackRowControl Grid.Column="0"
                                                                      Title="{Binding Title}"
                                                                      Artist="{Binding ArtistName}"
                                                                      Album="{Binding AlbumTitle}"
                                                                      Duration="{Binding DurationFormatted}"
                                                                      CoverArtUrl="{Binding CoverArtUrl}"
                                                                      Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      CommandParameter="{Binding}"/>
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    Command="{Binding DataContext.StartWaveFromTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="10,0,0,0">
                                                <TextBlock Text="Wave"/>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <Border Style="{StaticResource SurfaceCardStyle}" Visibility="{Binding HasFavoriteArtists, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Favorite Artists" Style="{StaticResource DisplaySectionTextStyle}"/>
                            <TextBlock Text="{Binding FavoriteArtistsSummary}" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,14"/>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding FavoriteArtists}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <controls:ArtistCircleCard ArtistName="{Binding Name}"
                                                                       ImageUrl="{Binding ImageUrl}"
                                                                       Command="{Binding DataContext.NavigateToArtistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                       CommandParameter="{Binding Id}"
                                                                       Margin="0,0,14,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,18,0,0" Visibility="{Binding HasSuggestedAlbums, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Albums You May Like" Style="{StaticResource DisplaySectionTextStyle}"/>
                            <TextBlock Text="{Binding AlbumShelfSummary}" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,14"/>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding SuggestedAlbums}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <controls:AlbumCard Title="{Binding Title}"
                                                                Artist="{Binding ArtistName}"
                                                                CoverArtUrl="{Binding CoverArtUrl}"
                                                                Year="{Binding ReleaseYear}"
                                                                Command="{Binding DataContext.NavigateToAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding Id}"
                                                                Margin="0,0,14,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Snippet Preview" Style="{StaticResource DisplaySectionTextStyle}"/>
                            <TextBlock Text="Fast entry points into promising moments without leaving the desktop shell." Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,14"/>
                            <ItemsControl ItemsSource="{Binding SnippetMoments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource InsetSurfaceCardStyle}" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Track.Title}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                                <TextBlock Text="{Binding Detail}" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                    <Button Content="Play Snippet" Style="{StaticResource GhostButtonStyle}" Command="{Binding DataContext.PlaySnippetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding StartLabel}" Style="{StaticResource SmallCaptionTextStyle}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
