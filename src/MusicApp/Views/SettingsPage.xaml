<UserControl x:Class="MusicApp.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer Style="{StaticResource ScrollViewerStyle}"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,36">
            <Border Style="{StaticResource HeroSurfaceCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="SETTINGS" Style="{StaticResource SectionEyebrowTextStyle}"/>
                        <TextBlock Text="Playback, discovery, storage, interface, and lyrics stay configurable inside the same workspace."
                                   Style="{StaticResource HeroTextStyle}"
                                   FontSize="38"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding PlaybackSummary}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,14,0,0"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding DiscoverySummary}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{Binding VolumePercent}" Style="{StaticResource MetricValueTextStyle}"/>
                                <TextBlock Text="Default Volume" Style="{StaticResource MetricLabelTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding CacheSizeFormatted}" Style="{StaticResource MetricValueTextStyle}" FontSize="26"/>
                                <TextBlock Text="Cache Size" Style="{StaticResource MetricLabelTextStyle}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.8*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Playback" Style="{StaticResource DisplaySectionTextStyle}"/>
                            <TextBlock Text="{Binding PlaybackSummary}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="Default volume" Style="{StaticResource LabelTextStyle}" Margin="0,16,0,0"/>
                            <Slider Style="{StaticResource SliderStyle}"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,10,0,0"/>

                            <CheckBox Content="Auto-scan local library on startup"
                                      Style="{StaticResource CheckBoxStyle}"
                                      IsChecked="{Binding AutoScanOnStartup}"
                                      Margin="0,18,0,0"/>
                            <CheckBox Content="Enable smart downloads"
                                      Style="{StaticResource CheckBoxStyle}"
                                      IsChecked="{Binding EnableSmartDownloads}"
                                      Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Discovery / My Wave" Style="{StaticResource DisplaySectionTextStyle}"/>
                            <TextBlock Text="{Binding DiscoverySummary}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="Familiarity" Style="{StaticResource LabelTextStyle}" Margin="0,16,0,0"/>
                            <Slider Style="{StaticResource SliderStyle}"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="{Binding DiscoveryBalance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,10,0,0"/>

                            <TextBlock Text="Popularity" Style="{StaticResource LabelTextStyle}" Margin="0,16,0,0"/>
                            <Slider Style="{StaticResource SliderStyle}"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="{Binding PopularityBalance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,10,0,0"/>

                            <TextBlock Text="Artist variety" Style="{StaticResource LabelTextStyle}" Margin="0,16,0,0"/>
                            <Slider Style="{StaticResource SliderStyle}"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="{Binding ArtistVariety, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,10,0,0"/>

                            <TextBlock Text="Energy bias" Style="{StaticResource LabelTextStyle}" Margin="0,16,0,0"/>
                            <Slider Style="{StaticResource SliderStyle}"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="{Binding EnergyBalance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Lyrics &amp; Interface" Style="{StaticResource DisplaySectionTextStyle}"/>
                            <TextBlock Text="{Binding LyricsSummary}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>

                            <CheckBox Content="Prefer synced lyrics when timestamps exist"
                                      Style="{StaticResource CheckBoxStyle}"
                                      IsChecked="{Binding PreferSyncedLyrics}"
                                      Margin="0,16,0,0"/>
                            <CheckBox Content="Auto-scroll lyrics with playback"
                                      Style="{StaticResource CheckBoxStyle}"
                                      IsChecked="{Binding AutoScrollLyrics}"
                                      Margin="0,10,0,0"/>
                            <CheckBox Content="Enable smart queue after the explicit queue ends"
                                      Style="{StaticResource CheckBoxStyle}"
                                      IsChecked="{Binding SmartQueueEnabled}"
                                      Margin="0,10,0,0"/>
                            <CheckBox Content="Show contextual right panel by default"
                                      Style="{StaticResource CheckBoxStyle}"
                                      IsChecked="{Binding ShowContextPanelByDefault}"
                                      Margin="0,10,0,0"/>
                            <CheckBox Content="Start with compact sidebar"
                                      Style="{StaticResource CheckBoxStyle}"
                                      IsChecked="{Binding CompactSidebar}"
                                      Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="18,0,0,0">
                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Cache &amp; Storage" Style="{StaticResource DisplaySectionTextStyle}"/>
                            <TextBlock Text="{Binding CacheSizeFormatted}"
                                       Style="{StaticResource TitleTextStyle}"
                                       Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding OfflineSummary}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,10,0,0"
                                       TextWrapping="Wrap"/>
                            <WrapPanel Margin="0,18,0,0">
                                <Button Content="Refresh"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding RefreshCacheSizeCommand}"
                                        Margin="0,0,10,10"/>
                                <Button Content="Clear Cache"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding ClearCacheCommand}"
                                        Margin="0,0,0,10"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Services" Style="{StaticResource DisplaySectionTextStyle}"/>
                            <TextBlock Text="{Binding ServicesSummary}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>
                            <CheckBox Content="Enable SoundCloud integration"
                                      Style="{StaticResource CheckBoxStyle}"
                                      IsChecked="{Binding EnableSoundCloud}"
                                      Margin="0,16,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Playback Quality" Style="{StaticResource DisplaySectionTextStyle}"/>
                            <TextBlock Text="{Binding QualitySummary}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Privacy &amp; Social" Style="{StaticResource DisplaySectionTextStyle}"/>
                            <TextBlock Text="{Binding PrivacySummary}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="About" Style="{StaticResource DisplaySectionTextStyle}"/>
                            <TextBlock Text="This client is built as a Windows-first product foundation in C# + WPF + .NET 8, with honest extension points for sync, social, and richer playback routing."
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
