<UserControl x:Class="MusicApp.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer Style="{StaticResource ScrollViewerStyle}"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,36">
            <TextBlock Text="Settings"
                       Style="{StaticResource HeroTextStyle}"/>
            <TextBlock Text="Playback, discovery, interface, cache, lyrics, and provider controls live here."
                       Style="{StaticResource SubtitleTextStyle}"
                       Margin="0,10,0,0"/>

            <Grid Margin="0,22,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Playback"
                                       Style="{StaticResource TitleTextStyle}"
                                       FontSize="24"/>
                            <TextBlock Text="Default volume"
                                       Style="{StaticResource LabelTextStyle}"
                                       Margin="0,14,0,0"/>
                            <Slider Style="{StaticResource SliderStyle}"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,10,0,0"/>
                            <CheckBox Content="Auto-scan local library on startup"
                                      Style="{StaticResource CheckBoxStyle}"
                                      IsChecked="{Binding AutoScanOnStartup}"
                                      Margin="0,18,0,0"/>
                            <CheckBox Content="Enable smart downloads"
                                      Style="{StaticResource CheckBoxStyle}"
                                      IsChecked="{Binding EnableSmartDownloads}"
                                      Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Discovery / My Wave"
                                       Style="{StaticResource TitleTextStyle}"
                                       FontSize="24"/>
                            <TextBlock Text="Familiarity"
                                       Style="{StaticResource LabelTextStyle}"
                                       Margin="0,14,0,0"/>
                            <Slider Style="{StaticResource SliderStyle}"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="{Binding DiscoveryBalance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,10,0,0"/>
                            <TextBlock Text="Popularity"
                                       Style="{StaticResource LabelTextStyle}"
                                       Margin="0,14,0,0"/>
                            <Slider Style="{StaticResource SliderStyle}"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="{Binding PopularityBalance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,10,0,0"/>
                            <TextBlock Text="Artist variety"
                                       Style="{StaticResource LabelTextStyle}"
                                       Margin="0,14,0,0"/>
                            <Slider Style="{StaticResource SliderStyle}"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="{Binding ArtistVariety, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,10,0,0"/>
                            <TextBlock Text="Energy"
                                       Style="{StaticResource LabelTextStyle}"
                                       Margin="0,14,0,0"/>
                            <Slider Style="{StaticResource SliderStyle}"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="{Binding EnergyBalance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Lyrics, Queue, Interface"
                                       Style="{StaticResource TitleTextStyle}"
                                       FontSize="24"/>
                            <CheckBox Content="Prefer synced lyrics when timestamps exist"
                                      Style="{StaticResource CheckBoxStyle}"
                                      IsChecked="{Binding PreferSyncedLyrics}"
                                      Margin="0,14,0,0"/>
                            <CheckBox Content="Auto-scroll lyrics with playback"
                                      Style="{StaticResource CheckBoxStyle}"
                                      IsChecked="{Binding AutoScrollLyrics}"
                                      Margin="0,10,0,0"/>
                            <CheckBox Content="Enable smart queue after the explicit queue ends"
                                      Style="{StaticResource CheckBoxStyle}"
                                      IsChecked="{Binding SmartQueueEnabled}"
                                      Margin="0,10,0,0"/>
                            <CheckBox Content="Show contextual right panel by default"
                                      Style="{StaticResource CheckBoxStyle}"
                                      IsChecked="{Binding ShowContextPanelByDefault}"
                                      Margin="0,10,0,0"/>
                            <CheckBox Content="Start with compact sidebar"
                                      Style="{StaticResource CheckBoxStyle}"
                                      IsChecked="{Binding CompactSidebar}"
                                      Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Cache / Storage"
                                       Style="{StaticResource TitleTextStyle}"
                                       FontSize="24"/>
                            <TextBlock Text="{Binding CacheSizeFormatted}"
                                       Style="{StaticResource SubtitleTextStyle}"
                                       Margin="0,14,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                <Button Content="Refresh"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding RefreshCacheSizeCommand}"
                                        Margin="0,0,10,0"/>
                                <Button Content="Clear Cache"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding ClearCacheCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Services"
                                       Style="{StaticResource TitleTextStyle}"
                                       FontSize="24"/>
                            <CheckBox Content="Enable SoundCloud integration"
                                      Style="{StaticResource CheckBoxStyle}"
                                      IsChecked="{Binding EnableSoundCloud}"
                                      Margin="0,14,0,0"/>
                            <TextBlock Text="Spotify remains disabled in this build because its search and playback foundation are still intentionally absent."
                                       Style="{StaticResource CaptionTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="About"
                                       Style="{StaticResource TitleTextStyle}"
                                       FontSize="24"/>
                            <TextBlock Text="This Windows client is built with C# + WPF + .NET 8 and keeps incomplete capabilities honest instead of faking production readiness."
                                       Style="{StaticResource CaptionTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,14,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
