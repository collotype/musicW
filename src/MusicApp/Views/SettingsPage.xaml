<UserControl x:Class="MusicApp.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}">

    <ScrollViewer Style="{StaticResource ScrollViewerStyle}"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32">
            <TextBlock Text="Settings"
                       Style="{StaticResource HeroTextStyle}"
                       Margin="0,0,0,32"/>

            <!-- Audio Section -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="12"
                    Padding="24"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Audio"
                               Style="{StaticResource TitleTextStyle}"
                               Margin="0,0,0,16"/>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Default Volume"
                                       FontSize="14"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock Text="{Binding Volume, Converter={StaticResource DoubleToPercentConverter}, StringFormat={}{0:F0}%}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        <Slider Grid.Column="1"
                                Style="{StaticResource SliderStyle}"
                                Width="150"
                                Minimum="0"
                                Maximum="100"
                                Value="{Binding Volume, Converter={StaticResource DoubleToPercentConverter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Cache Section -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="12"
                    Padding="24"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Cache"
                               Style="{StaticResource TitleTextStyle}"
                               Margin="0,0,0,16"/>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Image Cache"
                                       FontSize="14"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock Text="{Binding CacheSizeFormatted}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Refresh"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Command="{Binding RefreshCacheSizeCommand}"
                                    Margin="0,0,8,0"/>
                            <Button Content="Clear Cache"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding ClearCacheCommand}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Library Section -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="12"
                    Padding="24"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Library"
                               Style="{StaticResource TitleTextStyle}"
                               Margin="0,0,0,16"/>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Auto-Scan on Startup"
                                       FontSize="14"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock Text="When enabled, MusicApp scans your configured folders and default Music folder on startup."
                                       Style="{StaticResource CaptionTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,16,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1"
                                  Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding AutoScanOnStartup}"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Providers Section -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="12"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="Providers"
                               Style="{StaticResource TitleTextStyle}"
                               Margin="0,0,0,16"/>

                    <Grid Margin="0,8,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="SoundCloud"
                                       FontSize="14"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock Text="Enable SoundCloud search and playback."
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1"
                                  Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding EnableSoundCloud}"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <Border Background="{StaticResource BorderLightBrush}"
                            CornerRadius="10"
                            Padding="16">
                        <TextBlock Text="Spotify is disabled in this build because search and playback are not implemented yet."
                                   Style="{StaticResource CaptionTextStyle}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
