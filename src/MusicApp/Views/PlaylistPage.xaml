<UserControl x:Class="MusicApp.Views.PlaylistPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MusicApp.Controls"
             Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <ScrollViewer Style="{StaticResource ScrollViewerStyle}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Playlist Header -->
                <Grid Margin="32,32,32,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Playlist Cover -->
                    <Border Grid.Column="0"
                            CornerRadius="12"
                            Width="200"
                            Height="200">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding Playlist.CoverArtUrl}" Stretch="UniformToFill"/>
                        </Border.Background>
                        <Border x:Name="coverPlaceholder"
                                Background="{StaticResource BorderLightBrush}"
                                CornerRadius="12">
                            <TextBlock Text="📋"
                                       FontSize="64"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                        </Border>
                    </Border>

                    <!-- Playlist Info -->
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Bottom"
                                Margin="32,0,0,20">
                        <TextBlock Text="PLAYLIST"
                                   Style="{StaticResource LabelTextStyle}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Playlist.Title, FallbackValue='Playlist Title'}"
                                   Style="{StaticResource HeroTextStyle}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding Playlist.OwnerName, FallbackValue='Owner'}"
                                   Style="{StaticResource SubtitleTextStyle}"
                                   Margin="0,8,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <TextBlock Text="{Binding Playlist.TotalTracks, FallbackValue='0'}"
                                       Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text=" tracks"
                                       Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text=" • "
                                       Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text="{Binding Playlist.TotalDurationFormatted, FallbackValue='0 min'}"
                                       Style="{StaticResource CaptionTextStyle}"/>
                        </StackPanel>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                            <Button Content="Play All"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding PlayAllCommand}"
                                    Margin="0,0,12,0"/>
                            <Button Content="Search"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,12,0"/>
                            <Button Content="Edit"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Command="{Binding ToggleEditCommand}"
                                    Visibility="{Binding Playlist.IsSystemPlaylist, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}"/>
                            <controls:OverflowButton/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Search in Playlist (when editing) -->
                <Border Margin="32,24,32,0"
                        Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBox Style="{StaticResource SearchBoxStyle}"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,100,0"/>
                </Border>

                <!-- Track List -->
                <StackPanel Margin="0,24,0,32">
                    <ItemsControl ItemsSource="{Binding Playlist.Tracks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="32,0,32,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <controls:TrackRowControl Grid.Column="0"
                                                              Title="{Binding Title}"
                                                              Artist="{Binding ArtistName}"
                                                              Album="{Binding AlbumTitle}"
                                                              Duration="{Binding DurationFormatted}"
                                                              CoverArtUrl="{Binding CoverArtUrl}"
                                                              IsLiked="{Binding IsLiked}"/>
                                    <Button Grid.Column="1"
                                            Content="Remove"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            Command="{Binding DataContext.RemoveTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
