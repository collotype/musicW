<Window x:Class="MusicApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:MusicApp.Controls"
        mc:Ignorable="d"
        Title="MusicApp"
        Height="900"
        Width="1440"
        MinHeight="600"
        MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">

    <Window.InputBindings>
        <KeyBinding Key="Space" Command="{Binding PlayPauseCommand}"/>
        <KeyBinding Key="Right" Modifiers="Ctrl" Command="{Binding NextCommand}"/>
        <KeyBinding Key="Left" Modifiers="Ctrl" Command="{Binding PreviousCommand}"/>
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding NavigateToSearchCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <!-- Nav Rail -->
                <ColumnDefinition Width="64"/>
                <!-- Library Sidebar -->
                <ColumnDefinition Width="280" MinWidth="200" MaxWidth="400"/>
                <!-- Main Content -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Navigation Rail -->
            <Border Grid.Column="0"
                    Background="{StaticResource NavRailBackgroundBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="80"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo/Avatar -->
                    <Border Grid.Row="0"
                            Width="40"
                            Height="40"
                            CornerRadius="20"
                            Margin="0,20,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{StaticResource AccentPrimary}" Offset="0"/>
                                <GradientStop Color="{StaticResource AccentMuted}" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="♪"
                                   FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#0B0B0C"/>
                    </Border>

                    <!-- Main Navigation -->
                    <StackPanel Grid.Row="1"
                                VerticalAlignment="Top"
                                Margin="0,24,0,0">
                        <controls:NavRailButton Icon="🏠"
                                                Label="Home"
                                                IsActive="{Binding CurrentPageType, Converter={StaticResource PageTypeMatchConverter}, ConverterParameter=Library}"
                                                Command="{Binding NavigateToLibraryCommand}"
                                                HorizontalAlignment="Center"
                                                Margin="0,0,0,8"/>
                        <controls:NavRailButton Icon="🔍"
                                                Label="Search"
                                                IsActive="{Binding CurrentPageType, Converter={StaticResource PageTypeMatchConverter}, ConverterParameter=Search}"
                                                Command="{Binding NavigateToSearchCommand}"
                                                HorizontalAlignment="Center"
                                                Margin="0,0,0,8"/>
                    </StackPanel>

                    <!-- Profile/Settings -->
                    <StackPanel Grid.Row="2"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,24">
                        <controls:NavRailButton Icon="⚙"
                                                Label="Settings"
                                                IsActive="{Binding CurrentPageType, Converter={StaticResource PageTypeMatchConverter}, ConverterParameter=Settings}"
                                                Command="{Binding NavigateToSettingsCommand}"
                                                HorizontalAlignment="Center"/>
                        <controls:NavRailProfileButton AvatarUrl=""
                                                       UserName="User"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Library Sidebar -->
            <Border Grid.Column="1"
                    Background="{StaticResource SidebarBackgroundBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,0,1,0"
                    Visibility="{Binding IsLibrarySidebarVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="64"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Padding="20,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Your Library"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="+"
                                    Style="{StaticResource IconButtonStyle}"
                                    Width="32"
                                    Height="32"
                                    Command="{Binding Library.CreatePlaylistCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Collections List -->
                    <ScrollViewer Grid.Row="1"
                                  Style="{StaticResource ScrollViewerStyle}"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,8,0,16">
                            <!-- System Playlists -->
                            <controls:SidebarCollectionItem Title="Liked Songs"
                                                            Subtitle="{Binding Library.LikedCount}"
                                                            ThumbnailUrl=""
                                                            IsActive="{Binding Library.SelectedPlaylistId, Converter={StaticResource StringMatchConverter}, ConverterParameter=favorites}"
                                                            Command="{Binding Library.NavigateToFavoritesCommand}"/>
                            <controls:SidebarCollectionItem Title="Offline Tracks"
                                                            Subtitle="{Binding Library.OfflineCount}"
                                                            ThumbnailUrl=""
                                                            IsActive="{Binding Library.SelectedPlaylistId, Converter={StaticResource StringMatchConverter}, ConverterParameter=offline}"
                                                            Command="{Binding Library.NavigateToOfflineCommand}"/>

                            <!-- User Playlists -->
                            <TextBlock Text="Playlists"
                                       Style="{StaticResource LabelTextStyle}"
                                       Margin="20,24,20,8"/>
                            <ItemsControl ItemsSource="{Binding Library.Playlists}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <controls:SidebarCollectionItem Title="{Binding Title}"
                                                                        Subtitle="{Binding TotalTracks}"
                                                                        ThumbnailUrl="{Binding CoverArtUrl}"
                                                                        Command="{Binding DataContext.Library.NavigateToPlaylistCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding Id}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Create Playlist Button -->
                    <Button Grid.Row="2"
                            Content="Create Playlist"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="20"
                            Command="{Binding Library.CreatePlaylistCommand}"/>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Border Grid.Column="2"
                    Background="{StaticResource MainPanelBackgroundBrush}">
                <ContentControl Content="{Binding CurrentPage}"/>
            </Border>
        </Grid>

        <!-- Bottom Player -->
        <Border Grid.Row="1"
                Background="{StaticResource PlayerBackgroundBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Height="96">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- Now Playing (Left) -->
                <controls:NowPlayingMiniCard Grid.Column="0"
                                             Title="{Binding NowPlaying.Title}"
                                             Artist="{Binding NowPlaying.Artist}"
                                             CoverArtUrl="{Binding NowPlaying.CoverArtUrl}"
                                             IsLiked="{Binding NowPlaying.IsLiked}"
                                             LikeCommand="{Binding NowPlaying.ToggleLikeCommand}"
                                             Margin="16,0,0,0"
                                             VerticalAlignment="Center"/>

                <!-- Playback Controls (Center) -->
                <controls:PlaybackControls Grid.Column="1"
                                           IsPlaying="{Binding NowPlaying.IsPlaying}"
                                           IsShuffle="{Binding NowPlaying.IsShuffle}"
                                           RepeatMode="{Binding NowPlaying.RepeatMode}"
                                           ToggleShuffleCommand="{Binding NowPlaying.ToggleShuffleCommand}"
                                           PreviousCommand="{Binding NowPlaying.PreviousCommand}"
                                           PlayPauseCommand="{Binding NowPlaying.TogglePlayPauseCommand}"
                                           NextCommand="{Binding NowPlaying.NextCommand}"
                                           CycleRepeatModeCommand="{Binding NowPlaying.CycleRepeatModeCommand}"
                                           VerticalAlignment="Center"/>

                <!-- Progress & Volume (Right) -->
                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0">
                    <!-- Progress Bar -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding NowPlaying.CurrentPositionFormatted}"
                                   Style="{StaticResource SmallCaptionTextStyle}"
                                   VerticalAlignment="Center"/>
                        <Slider Grid.Column="1"
                                Style="{StaticResource SliderStyle}"
                                Minimum="0"
                                Maximum="100"
                                Value="{Binding NowPlaying.Progress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Margin="8,0"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding NowPlaying.TotalDurationFormatted}"
                                   Style="{StaticResource SmallCaptionTextStyle}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Volume Control -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Style="{StaticResource IconButtonStyle}"
                                Width="32"
                                Height="32"
                                Command="{Binding NowPlaying.ToggleMuteCommand}">
                            <TextBlock Text="{Binding NowPlaying.IsMuted, Converter={StaticResource VolumeIconConverter}}"
                                       FontSize="16"/>
                        </Button>
                        <controls:VolumeSlider Minimum="0"
                                               Maximum="100"
                                               Value="{Binding NowPlaying.Volume, Converter={StaticResource DoubleToPercentConverter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                               Margin="8,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding NowPlaying.ErrorMessage}"
                               Foreground="{StaticResource ErrorBrush}"
                               Style="{StaticResource SmallCaptionTextStyle}"
                               TextAlignment="Right"
                               Visibility="{Binding NowPlaying.HasError, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Background="#D9101113"
              Visibility="{Binding IsStartupBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="360"
                    Padding="28"
                    CornerRadius="16"
                    Background="{StaticResource ElevatedSurfaceBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Starting MusicApp"
                               Style="{StaticResource TitleTextStyle}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding StartupStatusMessage}"
                               Style="{StaticResource SubtitleTextStyle}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0"/>
                    <ProgressBar IsIndeterminate="True"
                                 Height="6"
                                 Margin="0,20,0,0"/>
                    <TextBlock Text="{Binding StartupErrorMessage}"
                               Foreground="{StaticResource ErrorBrush}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,16,0,0"
                               Visibility="{Binding StartupErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
