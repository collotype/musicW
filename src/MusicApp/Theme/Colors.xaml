<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background Colors -->
    <Color x:Key="AppBackground">#0B0B0C</Color>
    <Color x:Key="MainPanelBackground">#101113</Color>
    <Color x:Key="ElevatedSurface">#17181B</Color>
    <Color x:Key="ElevatedSurfaceHover">#1E1F23</Color>
    <Color x:Key="NavRailBackground">#0F1012</Color>
    <Color x:Key="SidebarBackground">#0D0E10</Color>
    <Color x:Key="PlayerBackground">#0E0F11</Color>
    <Color x:Key="CardBackground">#151618</Color>
    <Color x:Key="HeroOverlayBackground">#1A1B1E</Color>

    <!-- Border Colors -->
    <Color x:Key="BorderSubtle">#1A1B1E</Color>
    <Color x:Key="BorderLight">#25262A</Color>
    <Color x:Key="BorderAccent">#2D2E33</Color>

    <!-- Text Colors -->
    <Color x:Key="PrimaryText">#F4F4F4</Color>
    <Color x:Key="SecondaryText">#A8A8A8</Color>
    <Color x:Key="TertiaryText">#6B6B6B</Color>
    <Color x:Key="PlaceholderText">#4A4A4A</Color>

    <!-- Accent Colors - Pale Mint/Cyan -->
    <Color x:Key="AccentPrimary">#B8E6D5</Color>
    <Color x:Key="AccentPrimaryHover">#A0D4C3</Color>
    <Color x:Key="AccentPrimaryPressed">#8BC2B1</Color>
    <Color x:Key="AccentSecondary">#C4E8D9</Color>
    <Color x:Key="AccentMuted">#7A9B91</Color>

    <!-- State Colors -->
    <Color x:Key="Success">#6BC97D</Color>
    <Color x:Key="Warning">#E8B86D</Color>
    <Color x:Key="Error">#E57373</Color>
    <Color x:Key="Info">#64B5F6</Color>

    <!-- Selection & Hover -->
    <Color x:Key="SelectionBackground">#1F2024</Color>
    <Color x:Key="HoverBackground">#25262A</Color>
    <Color x:Key="ActiveNavBackground">#1E1F23</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackground}"/>
    <SolidColorBrush x:Key="MainPanelBackgroundBrush" Color="{StaticResource MainPanelBackground}"/>
    <SolidColorBrush x:Key="ElevatedSurfaceBrush" Color="{StaticResource ElevatedSurface}"/>
    <SolidColorBrush x:Key="ElevatedSurfaceHoverBrush" Color="{StaticResource ElevatedSurfaceHover}"/>
    <SolidColorBrush x:Key="NavRailBackgroundBrush" Color="{StaticResource NavRailBackground}"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackground}"/>
    <SolidColorBrush x:Key="PlayerBackgroundBrush" Color="{StaticResource PlayerBackground}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="HeroOverlayBackgroundBrush" Color="{StaticResource HeroOverlayBackground}"/>

    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLight}"/>
    <SolidColorBrush x:Key="BorderAccentBrush" Color="{StaticResource BorderAccent}"/>

    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryText}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryText}"/>
    <SolidColorBrush x:Key="TertiaryTextBrush" Color="{StaticResource TertiaryText}"/>
    <SolidColorBrush x:Key="PlaceholderTextBrush" Color="{StaticResource PlaceholderText}"/>

    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimary}"/>
    <SolidColorBrush x:Key="AccentPrimaryHoverBrush" Color="{StaticResource AccentPrimaryHover}"/>
    <SolidColorBrush x:Key="AccentPrimaryPressedBrush" Color="{StaticResource AccentPrimaryPressed}"/>
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource AccentSecondary}"/>
    <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMuted}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource Error}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Info}"/>

    <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="{StaticResource SelectionBackground}"/>
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="{StaticResource HoverBackground}"/>
    <SolidColorBrush x:Key="ActiveNavBackgroundBrush" Color="{StaticResource ActiveNavBackground}"/>

    <!-- Transparent Brushes -->
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>
    
    <!-- Border Opacity Brushes -->
    <SolidColorBrush x:Key="BorderSubtleOpacityBrush" Color="#0AFFFFFF"/>
    <SolidColorBrush x:Key="BorderLightOpacityBrush" Color="#0FFFFFFF"/>
    <SolidColorBrush x:Key="BorderAccentOpacityBrush" Color="#15FFFFFF"/>

</ResourceDictionary>
