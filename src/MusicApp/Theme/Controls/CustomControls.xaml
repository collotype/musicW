<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:MusicApp.Controls">

    <Style TargetType="controls:NavRailButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NavRailButton">
                    <Border x:Name="border"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            CornerRadius="12"
                            Background="{TemplateBinding Background}">
                        <TextBlock Text="{TemplateBinding Icon}"
                                   FontSize="18"
                                   Foreground="{TemplateBinding Foreground}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#12FFFFFF"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsActive" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#1FD5A35A"/>
                            <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:NavRailProfileButton">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NavRailProfileButton">
                    <Border Width="44"
                            Height="44"
                            CornerRadius="14"
                            Background="#14FFFFFF">
                        <TextBlock Text="You"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:SidebarCollectionItem" BasedOn="{StaticResource SidebarButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:SidebarCollectionItem">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}"
                            Margin="{TemplateBinding Margin}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="10"
                                    Background="{StaticResource ElevatedSurfaceBrush}">
                                <TextBlock Text="♪"
                                           FontSize="14"
                                           Foreground="{StaticResource AccentPrimaryBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Title}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{TemplateBinding Foreground}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{TemplateBinding Subtitle}"
                                           FontSize="11"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#12FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsActive" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#1FD5A35A"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:AlbumCard">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:AlbumCard">
                    <Border x:Name="border"
                            Width="190"
                            Padding="10"
                            CornerRadius="16"
                            Background="{TemplateBinding Background}">
                        <StackPanel>
                            <Border Height="190"
                                    CornerRadius="14"
                                    Background="{StaticResource ElevatedSurfaceBrush}">
                                <Grid>
                                    <Border CornerRadius="14">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{TemplateBinding CoverArtUrl}" Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>
                                    <Border x:Name="fallback"
                                            Visibility="Collapsed"
                                            CornerRadius="14"
                                            Background="{StaticResource ElevatedSurfaceBrush}">
                                        <TextBlock Text="Album"
                                                   Foreground="{StaticResource TertiaryTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <TextBlock Text="{TemplateBinding Title}"
                                       Margin="0,12,0,0"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{TemplateBinding Artist}"
                                       Margin="0,3,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{TemplateBinding Year}"
                                       Margin="0,6,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource TertiaryTextBrush}"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#10FFFFFF"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding CoverArtUrl, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                            <Setter TargetName="fallback" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CoverArtUrl, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                            <Setter TargetName="fallback" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:ArtistCircleCard">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:ArtistCircleCard">
                    <Border x:Name="border"
                            Width="156"
                            Padding="10"
                            CornerRadius="16"
                            Background="{TemplateBinding Background}">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="136"
                                    Height="136"
                                    CornerRadius="68"
                                    Background="{StaticResource ElevatedSurfaceBrush}">
                                <Grid>
                                    <Border CornerRadius="68">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{TemplateBinding ImageUrl}" Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>
                                    <Border x:Name="fallback"
                                            Visibility="Collapsed"
                                            CornerRadius="68"
                                            Background="{StaticResource ElevatedSurfaceBrush}">
                                        <TextBlock Text="Artist"
                                                   Foreground="{StaticResource TertiaryTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <TextBlock Text="{TemplateBinding ArtistName}"
                                       Margin="0,12,0,0"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#10FFFFFF"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding ImageUrl, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                            <Setter TargetName="fallback" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ImageUrl, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                            <Setter TargetName="fallback" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:PlaylistCard">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:PlaylistCard">
                    <Border x:Name="border"
                            Width="210"
                            Padding="10"
                            CornerRadius="16"
                            Background="{TemplateBinding Background}">
                        <StackPanel>
                            <Border Height="210"
                                    CornerRadius="14"
                                    Background="{StaticResource ElevatedSurfaceBrush}">
                                <Grid>
                                    <Border CornerRadius="14">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{TemplateBinding CoverArtUrl}" Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>
                                    <Border x:Name="fallback"
                                            Visibility="Collapsed"
                                            CornerRadius="14"
                                            Background="{StaticResource HeroGradientBrush}">
                                        <TextBlock Text="Playlist"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <TextBlock Text="{TemplateBinding Title}"
                                       Margin="0,12,0,0"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{TemplateBinding Subtitle}"
                                       Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#10FFFFFF"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding CoverArtUrl, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                            <Setter TargetName="fallback" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CoverArtUrl, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                            <Setter TargetName="fallback" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
