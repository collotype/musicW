<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:MusicApp.Controls">

    <!-- NavRailButton Style -->
    <Style TargetType="controls:NavRailButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="48"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NavRailButton">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{TemplateBinding Icon}"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource HoverBackgroundBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsActive" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ActiveNavBackgroundBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NavRailProfileButton Style -->
    <Style TargetType="controls:NavRailProfileButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NavRailProfileButton">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Width="48"
                            Height="48"
                            Padding="4">
                        <Border x:Name="avatarBorder"
                                CornerRadius="20"
                                Width="40"
                                Height="40">
                            <Border.Background>
                                <ImageBrush ImageSource="{TemplateBinding AvatarUrl}" Stretch="UniformToFill"/>
                            </Border.Background>
                            <Border x:Name="placeholder"
                                    Background="{StaticResource BorderLightBrush}"
                                    CornerRadius="20">
                                <TextBlock Text="👤"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                            </Border>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource HoverBackgroundBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- SidebarCollectionItem Style -->
    <Style TargetType="controls:SidebarCollectionItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Margin" Value="8,2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:SidebarCollectionItem">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}"
                            Margin="{TemplateBinding Margin}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    CornerRadius="6"
                                    Width="40"
                                    Height="40"
                                    Margin="0,0,12,0">
                                <Border.Background>
                                    <ImageBrush ImageSource="{TemplateBinding ThumbnailUrl}" Stretch="UniformToFill"/>
                                </Border.Background>
                                <Border x:Name="placeholder"
                                        Background="{StaticResource BorderLightBrush}"
                                        CornerRadius="6">
                                    <TextBlock Text="📁"
                                               FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                </Border>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Title}"
                                           FontSize="14"
                                           FontWeight="Medium"
                                           Foreground="{TemplateBinding Foreground}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{TemplateBinding Subtitle}"
                                           FontSize="12"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource HoverBackgroundBrush}"/>
                        </Trigger>
                        <Trigger Property="IsActive" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource SelectionBackgroundBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TrackCard Style -->
    <Style TargetType="controls:TrackCard">
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:TrackCard">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Width="180"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="140"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    CornerRadius="8"
                                    Margin="0,0,0,12">
                                <Border.Background>
                                    <ImageBrush ImageSource="{TemplateBinding CoverArtUrl}" Stretch="UniformToFill"/>
                                </Border.Background>
                                <Border x:Name="placeholder"
                                        Background="{StaticResource BorderLightBrush}"
                                        CornerRadius="8"/>
                            </Border>
                            <StackPanel Grid.Row="1">
                                <TextBlock Text="{TemplateBinding Title}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{TemplateBinding Foreground}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="40"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{TemplateBinding Artist}"
                                           FontSize="12"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,4,0,0"/>
                                <TextBlock Text="{TemplateBinding Duration}"
                                           FontSize="11"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ElevatedSurfaceHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- AlbumCard Style -->
    <Style TargetType="controls:AlbumCard">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:AlbumCard">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Width="200"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="160"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    CornerRadius="8"
                                    Margin="0,0,0,12">
                                <Border.Background>
                                    <ImageBrush ImageSource="{TemplateBinding CoverArtUrl}" Stretch="UniformToFill"/>
                                </Border.Background>
                                <Border x:Name="placeholder"
                                        Background="{StaticResource BorderLightBrush}"
                                        CornerRadius="8"/>
                            </Border>
                            <StackPanel Grid.Row="1">
                                <TextBlock Text="{TemplateBinding Title}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{TemplateBinding Foreground}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="40"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{TemplateBinding Artist}"
                                           FontSize="12"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,4,0,0"/>
                                <TextBlock Text="{TemplateBinding Year}"
                                           FontSize="11"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource HoverBackgroundBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ArtistCircleCard Style -->
    <Style TargetType="controls:ArtistCircleCard">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:ArtistCircleCard">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Width="140"
                            Padding="12">
                        <StackPanel HorizontalAlignment="Center">
                            <Border CornerRadius="70"
                                    Width="140"
                                    Height="140">
                                <Border.Background>
                                    <ImageBrush ImageSource="{TemplateBinding ImageUrl}" Stretch="UniformToFill"/>
                                </Border.Background>
                                <Border x:Name="placeholder"
                                        Background="{StaticResource BorderLightBrush}"
                                        CornerRadius="70">
                                    <TextBlock Text="🎤"
                                               FontSize="48"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                </Border>
                            </Border>
                            <TextBlock Text="{TemplateBinding ArtistName}"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="{TemplateBinding Foreground}"
                                       TextTrimming="CharacterEllipsis"
                                       TextAlignment="Center"
                                       Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource HoverBackgroundBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- PlaylistCard Style -->
    <Style TargetType="controls:PlaylistCard">
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:PlaylistCard">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Width="220"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="180"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    CornerRadius="8"
                                    Margin="0,0,0,12">
                                <Border.Background>
                                    <ImageBrush ImageSource="{TemplateBinding CoverArtUrl}" Stretch="UniformToFill"/>
                                </Border.Background>
                                <Border x:Name="placeholder"
                                        Background="{StaticResource BorderLightBrush}"
                                        CornerRadius="8"/>
                            </Border>
                            <StackPanel Grid.Row="1">
                                <TextBlock Text="{TemplateBinding Title}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{TemplateBinding Foreground}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="40"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{TemplateBinding Subtitle}"
                                           FontSize="12"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ElevatedSurfaceHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
