<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:MusicApp.Controls"
                    xmlns:enums="clr-namespace:MusicApp.Enums">

    <Style x:Key="PlayerUtilityButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            CornerRadius="14"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#14FFFFFF"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#22FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.42"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PlayerPrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource AppBackgroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            CornerRadius="20"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.92"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.82"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.42"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PlayerFilledTrackButtonStyle" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Background" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Height="3"
                            VerticalAlignment="Center"
                            CornerRadius="1.5"
                            Background="{TemplateBinding Background}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PlayerEmptyTrackButtonStyle" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Height="3"
                            VerticalAlignment="Center"
                            CornerRadius="1.5"
                            Background="{TemplateBinding Background}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:FavoriteButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:FavoriteButton">
                    <Border x:Name="border"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            CornerRadius="14"
                            Background="{TemplateBinding Background}">
                        <TextBlock x:Name="icon"
                                   Text="&#x2661;"
                                   FontSize="13"
                                   Foreground="{TemplateBinding Foreground}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="icon" Property="Text" Value="&#x2665;"/>
                            <Setter TargetName="icon" Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#14FFFFFF"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#22FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:NowPlayingMiniCard">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NowPlayingMiniCard">
                    <Grid MaxWidth="310"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="42"
                                Height="42"
                                CornerRadius="8"
                                Background="{StaticResource ElevatedSurfaceBrush}"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Border CornerRadius="8">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{TemplateBinding CoverArtUrl}"
                                                    Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>
                                <Border x:Name="coverFallback"
                                        CornerRadius="8"
                                        Background="{StaticResource ElevatedSurfaceBrush}"
                                        Visibility="Collapsed">
                                    <Grid>
                                        <Rectangle RadiusX="6"
                                                   RadiusY="6"
                                                   Margin="6"
                                                   Fill="#12FFFFFF"/>
                                        <TextBlock Text="&#x266A;"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Opacity="0.85"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Margin="10,0,10,0"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="titleText"
                                       Text="{TemplateBinding Title}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{TemplateBinding Foreground}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="artistText"
                                       Text="{TemplateBinding Artist}"
                                       FontSize="11"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <controls:FavoriteButton x:Name="likeButton"
                                                 Grid.Column="2"
                                                 VerticalAlignment="Center"
                                                 IsChecked="{TemplateBinding IsLiked}"
                                                 Command="{TemplateBinding LikeCommand}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding CoverArtUrl, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                            <Setter TargetName="coverFallback" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CoverArtUrl, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                            <Setter TargetName="coverFallback" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Title, RelativeSource={RelativeSource TemplatedParent}}" Value="Not Playing">
                            <Setter TargetName="titleText" Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
                            <Setter TargetName="artistText" Property="Text" Value="Pick something to start playback"/>
                            <Setter TargetName="artistText" Property="Foreground" Value="{StaticResource TertiaryTextBrush}"/>
                            <Setter TargetName="likeButton" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:PlaybackControls">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:PlaybackControls">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Button x:Name="repeatButton"
                                Style="{StaticResource PlayerUtilityButtonStyle}"
                                Command="{Binding CycleRepeatModeCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                Margin="0,0,4,0"
                                ToolTip="Repeat">
                            <Grid Width="16"
                                  Height="16">
                                <TextBlock Text="&#x21BB;"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Opacity="0.92"/>
                                <Border x:Name="repeatOneBadge"
                                        Width="10"
                                        Height="10"
                                        CornerRadius="5"
                                        Background="{StaticResource PlayerBackgroundBrush}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,-2,-2"
                                        Visibility="Collapsed">
                                    <TextBlock Text="1"
                                               FontSize="7"
                                               FontWeight="Bold"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <Button Style="{StaticResource PlayerUtilityButtonStyle}"
                                Command="{Binding PreviousCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                Margin="0,0,4,0"
                                ToolTip="Previous">
                            <Grid Width="16"
                                  Height="14">
                                <Rectangle Width="2"
                                           Height="12"
                                           RadiusX="1"
                                           RadiusY="1"
                                           Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"/>
                                <Polygon Points="7.5,7 14.5,1.2 14.5,12.8"
                                         Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"/>
                                <Polygon Points="1.5,7 8.5,1.2 8.5,12.8"
                                         Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <Button Style="{StaticResource PlayerPrimaryButtonStyle}"
                                Command="{Binding PlayPauseCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                Margin="2,0"
                                ToolTip="Play/Pause">
                            <Grid Width="16"
                                  Height="16">
                                <Polygon x:Name="playIcon"
                                         Points="3,1.5 14,8 3,14.5"
                                         Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                         Stretch="Fill"/>
                                <Grid x:Name="pauseIcon"
                                      Visibility="Collapsed">
                                    <Rectangle Width="4"
                                               Height="14"
                                               RadiusX="1"
                                               RadiusY="1"
                                               Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"/>
                                    <Rectangle Width="4"
                                               Height="14"
                                               RadiusX="1"
                                               RadiusY="1"
                                               Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Button>

                        <Button Style="{StaticResource PlayerUtilityButtonStyle}"
                                Command="{Binding NextCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                Margin="4,0,0,0"
                                ToolTip="Next">
                            <Grid Width="16"
                                  Height="14">
                                <Rectangle Width="2"
                                           Height="12"
                                           RadiusX="1"
                                           RadiusY="1"
                                           Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                                <Polygon Points="8.5,7 1.5,1.2 1.5,12.8"
                                         Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"/>
                                <Polygon Points="14.5,7 7.5,1.2 7.5,12.8"
                                         Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <Button x:Name="shuffleButton"
                                Style="{StaticResource PlayerUtilityButtonStyle}"
                                Command="{Binding ToggleShuffleCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                Margin="4,0,0,0"
                                ToolTip="Shuffle">
                            <TextBlock Text="&#x21C4;"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsPlaying, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                            <Setter TargetName="playIcon" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="pauseIcon" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsShuffle, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                            <Setter TargetName="shuffleButton" Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RepeatMode, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Static enums:RepeatMode.All}">
                            <Setter TargetName="repeatButton" Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RepeatMode, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Static enums:RepeatMode.One}">
                            <Setter TargetName="repeatButton" Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                            <Setter TargetName="repeatOneBadge" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:ProgressSlider">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="Background" Value="#20FFFFFF"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:ProgressSlider">
                    <Grid Height="{TemplateBinding Height}"
                          SnapsToDevicePixels="True">
                        <Border Height="3"
                                VerticalAlignment="Center"
                                CornerRadius="1.5"
                                Background="{TemplateBinding Background}"/>
                        <Track x:Name="PART_Track"
                               Minimum="{TemplateBinding Minimum}"
                               Maximum="{TemplateBinding Maximum}"
                               Value="{TemplateBinding Value}"
                               VerticalAlignment="Center"
                               Orientation="Horizontal"
                               IsDirectionReversed="False">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge"
                                              Background="{TemplateBinding Foreground}"
                                              Style="{StaticResource PlayerFilledTrackButtonStyle}"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb x:Name="thumb"
                                       Width="8"
                                       Height="8"
                                       Margin="-2,0,-2,0"
                                       Opacity="0"
                                       Focusable="False">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse Fill="{StaticResource PrimaryTextBrush}"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge"
                                              Style="{StaticResource PlayerEmptyTrackButtonStyle}"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="thumb" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger SourceName="thumb" Property="IsDragging" Value="True">
                            <Setter TargetName="thumb" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:VolumeSlider">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="Background" Value="#18FFFFFF"/>
        <Setter Property="Width" Value="92"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:VolumeSlider">
                    <Grid Height="{TemplateBinding Height}"
                          SnapsToDevicePixels="True">
                        <Border Height="3"
                                VerticalAlignment="Center"
                                CornerRadius="1.5"
                                Background="{TemplateBinding Background}"/>
                        <Track x:Name="PART_Track"
                               Minimum="{TemplateBinding Minimum}"
                               Maximum="{TemplateBinding Maximum}"
                               Value="{TemplateBinding Value}"
                               VerticalAlignment="Center"
                               Orientation="Horizontal"
                               IsDirectionReversed="False">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge"
                                              Background="{TemplateBinding Foreground}"
                                              Style="{StaticResource PlayerFilledTrackButtonStyle}"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb x:Name="thumb"
                                       Width="8"
                                       Height="8"
                                       Margin="-2,0,-2,0"
                                       Opacity="0"
                                       Focusable="False">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse Fill="{StaticResource PrimaryTextBrush}"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge"
                                              Style="{StaticResource PlayerEmptyTrackButtonStyle}"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="thumb" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger SourceName="thumb" Property="IsDragging" Value="True">
                            <Setter TargetName="thumb" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
