<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:MusicApp.Controls"
                    xmlns:enums="clr-namespace:MusicApp.Enums">

    <Style TargetType="controls:TrackRowControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:TrackRowControl">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="14"
                            Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{TemplateBinding TrackNumber}"
                                       FontSize="12"
                                       Foreground="{StaticResource TertiaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                            <Border Grid.Column="1"
                                    Width="44"
                                    Height="44"
                                    CornerRadius="10"
                                    Background="{StaticResource ElevatedSurfaceBrush}">
                                <Grid>
                                    <Border CornerRadius="10">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{TemplateBinding CoverArtUrl}" Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>
                                    <Border x:Name="coverFallback"
                                            Visibility="Collapsed"
                                            CornerRadius="10"
                                            Background="{StaticResource ElevatedSurfaceBrush}">
                                        <TextBlock Text="♪"
                                                   Foreground="{StaticResource AccentPrimaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Title}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{TemplateBinding Artist}"
                                           Margin="0,3,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <TextBlock Grid.Column="3"
                                       Text="{TemplateBinding Album}"
                                       FontSize="12"
                                       Foreground="{StaticResource TertiaryTextBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Margin="16,0,0,0"/>

                            <TextBlock Grid.Column="4"
                                       Text="{TemplateBinding Duration}"
                                       FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#10FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPlaying" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#1FD5A35A"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding CoverArtUrl, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                            <Setter TargetName="coverFallback" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CoverArtUrl, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                            <Setter TargetName="coverFallback" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:FavoriteButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:FavoriteButton">
                    <Border x:Name="border"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="14">
                        <TextBlock x:Name="icon"
                                   Text="♡"
                                   Foreground="{TemplateBinding Foreground}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="icon" Property="Text" Value="♥"/>
                            <Setter TargetName="icon" Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#12FFFFFF"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:NowPlayingMiniCard">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NowPlayingMiniCard">
                    <Grid MaxWidth="320">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Width="44"
                                Height="44"
                                CornerRadius="12"
                                Background="{StaticResource ElevatedSurfaceBrush}">
                            <Grid>
                                <Border CornerRadius="12">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{TemplateBinding CoverArtUrl}" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>
                                <Border x:Name="coverFallback"
                                        Visibility="Collapsed"
                                        CornerRadius="12"
                                        Background="{StaticResource ElevatedSurfaceBrush}">
                                    <TextBlock Text="♪"
                                               Foreground="{StaticResource AccentPrimaryBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,10,0" VerticalAlignment="Center">
                            <TextBlock Text="{TemplateBinding Title}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{TemplateBinding Artist}"
                                       Margin="0,2,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <controls:FavoriteButton Grid.Column="2"
                                                 IsChecked="{TemplateBinding IsLiked}"
                                                 Command="{TemplateBinding LikeCommand}"
                                                 VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding CoverArtUrl, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                            <Setter TargetName="coverFallback" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CoverArtUrl, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                            <Setter TargetName="coverFallback" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:PlaybackControls">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:PlaybackControls">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="shuffleButton"
                                Style="{StaticResource IconButtonStyle}"
                                Command="{Binding ToggleShuffleCommand, RelativeSource={RelativeSource TemplatedParent}}">
                            <TextBlock Text="⤮" FontSize="13"/>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle}"
                                Margin="6,0,0,0"
                                Command="{Binding PreviousCommand, RelativeSource={RelativeSource TemplatedParent}}">
                            <TextBlock Text="⏮" FontSize="15"/>
                        </Button>
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Width="42"
                                Height="42"
                                Padding="0"
                                Margin="8,0"
                                Command="{Binding PlayPauseCommand, RelativeSource={RelativeSource TemplatedParent}}">
                            <Grid>
                                <TextBlock x:Name="playIcon"
                                           Text="▶"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="pauseIcon"
                                           Text="⏸"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle}"
                                Margin="0,0,6,0"
                                Command="{Binding NextCommand, RelativeSource={RelativeSource TemplatedParent}}">
                            <TextBlock Text="⏭" FontSize="15"/>
                        </Button>
                        <Button x:Name="repeatButton"
                                Style="{StaticResource IconButtonStyle}"
                                Command="{Binding CycleRepeatModeCommand, RelativeSource={RelativeSource TemplatedParent}}">
                            <Grid>
                                <TextBlock Text="↻" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border x:Name="repeatOneBadge"
                                        Width="11"
                                        Height="11"
                                        CornerRadius="5.5"
                                        Background="{StaticResource AccentPrimaryBrush}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,-3,-3"
                                        Visibility="Collapsed">
                                    <TextBlock Text="1"
                                               FontSize="7"
                                               Foreground="#120E09"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsPlaying, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                            <Setter TargetName="playIcon" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="pauseIcon" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsShuffle, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                            <Setter TargetName="shuffleButton" Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RepeatMode, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Static enums:RepeatMode.All}">
                            <Setter TargetName="repeatButton" Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RepeatMode, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Static enums:RepeatMode.One}">
                            <Setter TargetName="repeatButton" Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                            <Setter TargetName="repeatOneBadge" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:ProgressSlider">
        <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="Background" Value="#18FFFFFF"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:ProgressSlider">
                    <Grid Height="{TemplateBinding Height}" SnapsToDevicePixels="True">
                        <Border Height="4"
                                VerticalAlignment="Center"
                                CornerRadius="2"
                                Background="{TemplateBinding Background}"/>
                        <Track x:Name="PART_Track"
                               Minimum="{TemplateBinding Minimum}"
                               Maximum="{TemplateBinding Maximum}"
                               Value="{TemplateBinding Value}"
                               VerticalAlignment="Center">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource PlayerFilledTrackButtonStyle}"
                                              Background="{TemplateBinding Foreground}"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb x:Name="thumb"
                                       Width="8"
                                       Height="8"
                                       Opacity="0">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse Fill="{StaticResource PrimaryTextBrush}"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource PlayerEmptyTrackButtonStyle}"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="thumb" Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:VolumeSlider">
        <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="Background" Value="#18FFFFFF"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="Width" Value="92"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:VolumeSlider">
                    <Grid Height="{TemplateBinding Height}" SnapsToDevicePixels="True">
                        <Border Height="4"
                                VerticalAlignment="Center"
                                CornerRadius="2"
                                Background="{TemplateBinding Background}"/>
                        <Track x:Name="PART_Track"
                               Minimum="{TemplateBinding Minimum}"
                               Maximum="{TemplateBinding Maximum}"
                               Value="{TemplateBinding Value}"
                               VerticalAlignment="Center">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource PlayerFilledTrackButtonStyle}"
                                              Background="{TemplateBinding Foreground}"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb x:Name="thumb"
                                       Width="8"
                                       Height="8"
                                       Opacity="0">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse Fill="{StaticResource PrimaryTextBrush}"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource PlayerEmptyTrackButtonStyle}"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="thumb" Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
