<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:MusicApp.Controls"
                    xmlns:enums="clr-namespace:MusicApp.Enums">

    <!-- TrackRowControl Style -->
    <Style TargetType="controls:TrackRowControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Height" Value="64"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:TrackRowControl">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <!-- Track Number / Play Icon -->
                            <TextBlock Grid.Column="0"
                                       x:Name="trackNumber"
                                       Text="{TemplateBinding TrackNumber}"
                                       FontSize="14"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="0"
                                       x:Name="playIcon"
                                       Text="▶"
                                       FontSize="14"
                                       Foreground="{StaticResource AccentPrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>

                            <!-- Cover Art + Title + Artist -->
                            <Grid Grid.Column="2" Margin="12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        CornerRadius="6"
                                        Width="48"
                                        Height="48">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{TemplateBinding CoverArtUrl}" Stretch="UniformToFill"/>
                                    </Border.Background>
                                    <Border x:Name="coverPlaceholder"
                                            Background="{StaticResource BorderLightBrush}"
                                            CornerRadius="6"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <TextBlock Text="{TemplateBinding Title}"
                                               FontSize="14"
                                               FontWeight="Medium"
                                               Foreground="{TemplateBinding Foreground}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{TemplateBinding Artist}"
                                               FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- Album (optional) -->
                            <TextBlock Grid.Column="3"
                                       Text="{TemplateBinding Album}"
                                       FontSize="13"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Margin="0,0,16,0"
                                       Visibility="Collapsed"/>

                            <!-- Duration -->
                            <TextBlock Grid.Column="4"
                                       Text="{TemplateBinding Duration}"
                                       FontSize="13"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource HoverBackgroundBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPlaying" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource SelectionBackgroundBrush}"/>
                            <Setter TargetName="trackNumber" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="playIcon" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- HeroHeader Style -->
    <Style TargetType="controls:HeroHeader">
        <Setter Property="Background" Value="{StaticResource HeroOverlayBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="Height" Value="280"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:HeroHeader">
                    <Grid>
                        <!-- Background Image with Blur -->
                        <Border x:Name="bgImage" Visibility="Collapsed">
                            <Border.Background>
                                <ImageBrush ImageSource="{TemplateBinding BackgroundImageUrl}" Stretch="UniformToFill"/>
                            </Border.Background>
                            <Border.Effect>
                                <BlurEffect Radius="50"/>
                            </Border.Effect>
                        </Border>

                        <!-- Gradient Overlay -->
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#00000000" Offset="0"/>
                                    <GradientStop Color="#0B0B0C" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- Content -->
                        <Grid Margin="32">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Cover/Avatar -->
                            <Border Grid.Column="0"
                                    CornerRadius="12"
                                    Width="200"
                                    Height="200"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom">
                                <Border.Background>
                                    <ImageBrush ImageSource="{TemplateBinding ImageUrl}" Stretch="UniformToFill"/>
                                </Border.Background>
                                <Border x:Name="imagePlaceholder"
                                        Background="{StaticResource BorderLightBrush}"
                                        CornerRadius="12">
                                    <TextBlock Text="🎵"
                                               FontSize="64"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                </Border>
                            </Border>

                            <!-- Text Content -->
                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Bottom"
                                        Margin="32,0,0,20">
                                <TextBlock Text="{TemplateBinding Label}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                <TextBlock Text="{TemplateBinding Title}"
                                           FontSize="48"
                                           FontWeight="Bold"
                                           Foreground="{TemplateBinding Foreground}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"/>
                                <TextBlock Text="{TemplateBinding Subtitle}"
                                           FontSize="16"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,12,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding BackgroundImageUrl, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                            <Setter TargetName="bgImage" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding BackgroundImageUrl, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                            <Setter TargetName="bgImage" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TagChip Style -->
    <Style TargetType="controls:TagChip">
        <Setter Property="Background" Value="{StaticResource BorderLightBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Margin" Value="0,0,8,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:TagChip">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="16"
                            Padding="{TemplateBinding Padding}">
                        <TextBlock Text="{TemplateBinding Text}"
                                   FontSize="12"
                                   Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource HoverBackgroundBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- FavoriteButton Style -->
    <Style TargetType="controls:FavoriteButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:FavoriteButton">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="16"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}">
                        <TextBlock x:Name="icon"
                                   Text="♡"
                                   FontSize="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="icon" Property="Text" Value="♥"/>
                            <Setter TargetName="icon" Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource HoverBackgroundBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- OverflowButton Style -->
    <Style TargetType="controls:OverflowButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:OverflowButton">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="16"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}">
                        <TextBlock Text="⋮"
                                   FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{TemplateBinding Foreground}"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="90"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource HoverBackgroundBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NowPlayingMiniCard Style -->
    <Style TargetType="controls:NowPlayingMiniCard">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NowPlayingMiniCard">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Cover Art -->
                        <Border Grid.Column="0"
                                CornerRadius="8"
                                Width="56"
                                Height="56">
                            <Border.Background>
                                <ImageBrush ImageSource="{TemplateBinding CoverArtUrl}" Stretch="UniformToFill"/>
                            </Border.Background>
                            <Border x:Name="placeholder"
                                    Background="{StaticResource BorderLightBrush}"
                                    CornerRadius="8"/>
                        </Border>

                        <!-- Title and Artist -->
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0">
                            <TextBlock Text="{TemplateBinding Title}"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="{TemplateBinding Foreground}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{TemplateBinding Artist}"
                                       FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Like Button -->
                        <controls:FavoriteButton Grid.Column="2"
                                                 IsChecked="{TemplateBinding IsLiked}"
                                                 Command="{TemplateBinding LikeCommand}"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- PlaybackControls Style -->
    <Style TargetType="controls:PlaybackControls">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:PlaybackControls">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <!-- Shuffle -->
                        <Button x:Name="shuffleBtn"
                                Style="{StaticResource IconButtonStyle}"
                                Command="{Binding ToggleShuffleCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                ToolTip="Shuffle">
                            <TextBlock Text="🔀" FontSize="16" Opacity="0.6"/>
                        </Button>

                        <!-- Previous -->
                        <Button x:Name="prevBtn"
                                Style="{StaticResource IconButtonStyle}"
                                Command="{Binding PreviousCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                ToolTip="Previous">
                            <TextBlock Text="⏮" FontSize="18"/>
                        </Button>

                        <!-- Play/Pause -->
                        <Button x:Name="playBtn"
                                Style="{StaticResource PlayButtonStyle}"
                                Width="48"
                                Height="48"
                                Margin="8,0"
                                Command="{Binding PlayPauseCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                ToolTip="Play/Pause">
                            <TextBlock x:Name="playIcon"
                                       Text="▶"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>

                        <!-- Next -->
                        <Button x:Name="nextBtn"
                                Style="{StaticResource IconButtonStyle}"
                                Command="{Binding NextCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                ToolTip="Next">
                            <TextBlock Text="⏭" FontSize="18"/>
                        </Button>

                        <!-- Repeat -->
                        <Button x:Name="repeatBtn"
                                Style="{StaticResource IconButtonStyle}"
                                Command="{Binding CycleRepeatModeCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                ToolTip="Repeat">
                            <TextBlock x:Name="repeatIcon"
                                       Text="🔁"
                                       FontSize="16"
                                       Opacity="0.6"/>
                        </Button>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsPlaying, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                            <Setter TargetName="playIcon" Property="Text" Value="⏸"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsShuffle, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                            <Setter TargetName="shuffleBtn" Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RepeatMode, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Static enums:RepeatMode.All}">
                            <Setter TargetName="repeatBtn" Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                            <Setter TargetName="repeatIcon" Property="Opacity" Value="1"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RepeatMode, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Static enums:RepeatMode.One}">
                            <Setter TargetName="repeatBtn" Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                            <Setter TargetName="repeatIcon" Property="Text" Value="🔂"/>
                            <Setter TargetName="repeatIcon" Property="Opacity" Value="1"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ProgressSlider Style -->
    <Style TargetType="controls:ProgressSlider">
        <Setter Property="Background" Value="{StaticResource BorderLightBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:ProgressSlider">
                    <Grid x:Name="grid" Height="20">
                        <!-- Track Background -->
                        <Border x:Name="trackBackground"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                Height="4"
                                VerticalAlignment="Center"/>
                        <!-- Progress Fill -->
                        <Canvas>
                            <Border x:Name="progressFill"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="2"
                                    Height="4"
                                    VerticalAlignment="Center"
                                    Canvas.Top="8"
                                    Width="{Binding ActualWidth, ElementName=thumb, Converter={StaticResource SliderProgressConverter}}"/>
                        </Canvas>
                        <!-- Thumb -->
                        <Thumb x:Name="thumb"
                               Width="12"
                               Height="12"
                               VerticalAlignment="Center">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Ellipse x:Name="ellipse"
                                             Fill="{StaticResource PrimaryTextBrush}"
                                             Width="12"
                                             Height="12"
                                             Opacity="0"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ellipse" Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- VolumeSlider Style -->
    <Style TargetType="controls:VolumeSlider">
        <Setter Property="Background" Value="{StaticResource BorderLightBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="Width" Value="100"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:VolumeSlider">
                    <Grid x:Name="grid" Height="20">
                        <Border x:Name="trackBackground"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                Height="4"
                                VerticalAlignment="Center"/>
                        <Border x:Name="progressFill"
                                Background="{TemplateBinding Foreground}"
                                CornerRadius="2"
                                Height="4"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Width="{Binding ActualWidth, ElementName=thumb}"/>
                        <Thumb x:Name="thumb"
                               Width="12"
                               Height="12"
                               VerticalAlignment="Center">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Ellipse x:Name="ellipse"
                                             Fill="{StaticResource PrimaryTextBrush}"
                                             Width="12"
                                             Height="12"
                                             Opacity="0"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ellipse" Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
