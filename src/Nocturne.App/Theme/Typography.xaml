<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <FontFamily x:Key="Font.Ui">pack://application:,,,/Assets/Fonts/#Manrope</FontFamily>
    <FontFamily x:Key="Font.Icon">Segoe Fluent Icons</FontFamily>

    <Style x:Key="Text.Display" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Ui}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="34" />
    </Style>

    <Style x:Key="Text.SectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Ui}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="21" />
    </Style>

    <Style x:Key="Text.Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Ui}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="Text.Caption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Ui}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
</ResourceDictionary>
