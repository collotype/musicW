<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Color.AppBackground">#070809</Color>
    <Color x:Key="Color.AppBackgroundAlt">#0A0B0D</Color>
    <Color x:Key="Color.ShellBackground">#0B0C0E</Color>
    <Color x:Key="Color.PanelBackground">#111315</Color>
    <Color x:Key="Color.PanelElevated">#16191C</Color>
    <Color x:Key="Color.PanelRaised">#1B1F24</Color>
    <Color x:Key="Color.PanelHover">#23292F</Color>
    <Color x:Key="Color.PanelContrast">#0E1012</Color>
    <Color x:Key="Color.Border">#16FFFFFF</Color>
    <Color x:Key="Color.BorderStrong">#26FFFFFF</Color>
    <Color x:Key="Color.TextPrimary">#F6F7F8</Color>
    <Color x:Key="Color.TextSecondary">#B7BBC1</Color>
    <Color x:Key="Color.TextMuted">#7B838C</Color>
    <Color x:Key="Color.Accent">#C3F5E7</Color>
    <Color x:Key="Color.AccentStrong">#9CE6D3</Color>
    <Color x:Key="Color.AccentDark">#0E241D</Color>
    <Color x:Key="Color.AccentSoft">#1FC3F5E7</Color>
    <Color x:Key="Color.Danger">#FF7A86</Color>

    <SolidColorBrush x:Key="Brush.AppBackground" Color="{StaticResource Color.AppBackground}" />
    <SolidColorBrush x:Key="Brush.AppBackgroundAlt" Color="{StaticResource Color.AppBackgroundAlt}" />
    <SolidColorBrush x:Key="Brush.ShellBackground" Color="{StaticResource Color.ShellBackground}" />
    <SolidColorBrush x:Key="Brush.PanelBackground" Color="{StaticResource Color.PanelBackground}" />
    <SolidColorBrush x:Key="Brush.PanelElevated" Color="{StaticResource Color.PanelElevated}" />
    <SolidColorBrush x:Key="Brush.PanelRaised" Color="{StaticResource Color.PanelRaised}" />
    <SolidColorBrush x:Key="Brush.PanelHover" Color="{StaticResource Color.PanelHover}" />
    <SolidColorBrush x:Key="Brush.PanelContrast" Color="{StaticResource Color.PanelContrast}" />
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="{StaticResource Color.BorderStrong}" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.AccentStrong" Color="{StaticResource Color.AccentStrong}" />
    <SolidColorBrush x:Key="Brush.AccentDark" Color="{StaticResource Color.AccentDark}" />
    <SolidColorBrush x:Key="Brush.AccentSoft" Color="{StaticResource Color.AccentSoft}" />
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}" />

    <LinearGradientBrush x:Key="Brush.BackgroundGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="{StaticResource Color.AppBackground}" />
        <GradientStop Offset="0.5" Color="#090A0C" />
        <GradientStop Offset="1" Color="{StaticResource Color.AppBackgroundAlt}" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.PanelGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#171A1D" />
        <GradientStop Offset="1" Color="#111315" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.HeaderOverlay" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#18000000" />
        <GradientStop Offset="0.4" Color="#42000000" />
        <GradientStop Offset="1" Color="#E1070809" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.HeroFade" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#2AC3F5E7" />
        <GradientStop Offset="0.32" Color="#0EFFFFFF" />
        <GradientStop Offset="1" Color="#00000000" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.CardImageOverlay" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#02000000" />
        <GradientStop Offset="0.65" Color="#09000000" />
        <GradientStop Offset="1" Color="#A0000000" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.NavSelection" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#32C3F5E7" />
        <GradientStop Offset="1" Color="#12FFFFFF" />
    </LinearGradientBrush>

    <RadialGradientBrush x:Key="Brush.DecorGlow" RadiusX="1.2" RadiusY="1.2">
        <GradientStop Offset="0" Color="#38C3F5E7" />
        <GradientStop Offset="0.5" Color="#10C3F5E7" />
        <GradientStop Offset="1" Color="#00000000" />
    </RadialGradientBrush>

    <CornerRadius x:Key="Radius.Small">12</CornerRadius>
    <CornerRadius x:Key="Radius.Medium">20</CornerRadius>
    <CornerRadius x:Key="Radius.Large">30</CornerRadius>
    <CornerRadius x:Key="Radius.XLarge">38</CornerRadius>
    <CornerRadius x:Key="Radius.Pill">999</CornerRadius>

    <Thickness x:Key="Spacing.XS">6</Thickness>
    <Thickness x:Key="Spacing.S">10</Thickness>
    <Thickness x:Key="Spacing.M">16</Thickness>
    <Thickness x:Key="Spacing.L">24</Thickness>
    <Thickness x:Key="Spacing.XL">32</Thickness>
    <Thickness x:Key="Spacing.XXL">40</Thickness>

    <DropShadowEffect x:Key="Effect.CardShadow"
                      BlurRadius="32"
                      ShadowDepth="0"
                      Color="#99000000"
                      Opacity="0.22" />
    <DropShadowEffect x:Key="Effect.HeroCoverShadow"
                      BlurRadius="46"
                      ShadowDepth="0"
                      Color="#E5000000"
                      Opacity="0.34" />
</ResourceDictionary>
