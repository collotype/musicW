<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Color.AppBackground">#09090A</Color>
    <Color x:Key="Color.ShellBackground">#0C0C0D</Color>
    <Color x:Key="Color.PanelBackground">#101113</Color>
    <Color x:Key="Color.PanelElevated">#17181B</Color>
    <Color x:Key="Color.PanelRaised">#1D1F23</Color>
    <Color x:Key="Color.PanelHover">#23252A</Color>
    <Color x:Key="Color.Border">#18FFFFFF</Color>
    <Color x:Key="Color.TextPrimary">#F4F4F4</Color>
    <Color x:Key="Color.TextSecondary">#A9AAAD</Color>
    <Color x:Key="Color.TextMuted">#75777D</Color>
    <Color x:Key="Color.Accent">#B7F9E4</Color>
    <Color x:Key="Color.AccentStrong">#93EED3</Color>
    <Color x:Key="Color.AccentDark">#10231D</Color>
    <Color x:Key="Color.Danger">#FF6F78</Color>

    <SolidColorBrush x:Key="Brush.AppBackground" Color="{StaticResource Color.AppBackground}" />
    <SolidColorBrush x:Key="Brush.ShellBackground" Color="{StaticResource Color.ShellBackground}" />
    <SolidColorBrush x:Key="Brush.PanelBackground" Color="{StaticResource Color.PanelBackground}" />
    <SolidColorBrush x:Key="Brush.PanelElevated" Color="{StaticResource Color.PanelElevated}" />
    <SolidColorBrush x:Key="Brush.PanelRaised" Color="{StaticResource Color.PanelRaised}" />
    <SolidColorBrush x:Key="Brush.PanelHover" Color="{StaticResource Color.PanelHover}" />
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.AccentStrong" Color="{StaticResource Color.AccentStrong}" />
    <SolidColorBrush x:Key="Brush.AccentDark" Color="{StaticResource Color.AccentDark}" />
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}" />

    <LinearGradientBrush x:Key="Brush.HeaderOverlay" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#22000000" />
        <GradientStop Offset="0.45" Color="#33000000" />
        <GradientStop Offset="1" Color="#E60A0A0B" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.HeroFade" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#1EB7F9E4" />
        <GradientStop Offset="0.35" Color="#0DFFFFFF" />
        <GradientStop Offset="1" Color="#00000000" />
    </LinearGradientBrush>

    <CornerRadius x:Key="Radius.Small">10</CornerRadius>
    <CornerRadius x:Key="Radius.Medium">18</CornerRadius>
    <CornerRadius x:Key="Radius.Large">28</CornerRadius>

    <Thickness x:Key="Spacing.XS">6</Thickness>
    <Thickness x:Key="Spacing.S">10</Thickness>
    <Thickness x:Key="Spacing.M">16</Thickness>
    <Thickness x:Key="Spacing.L">24</Thickness>
</ResourceDictionary>
