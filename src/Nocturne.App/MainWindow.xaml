<Window x:Class="Nocturne.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:Nocturne.App.Controls"
        mc:Ignorable="d"
        Title="Nocturne"
        Width="1580"
        Height="980"
        MinWidth="1320"
        MinHeight="860"
        WindowStyle="None"
        ResizeMode="CanResize">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8" />
    </shell:WindowChrome.WindowChrome>

    <Grid Background="{StaticResource Brush.BackgroundGradient}"
          PreviewKeyDown="Window_PreviewKeyDown">
        <Ellipse Width="540"
                 Height="540"
                 Margin="-160,-180,0,0"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Fill="{StaticResource Brush.DecorGlow}"
                 IsHitTestVisible="False" />
        <Ellipse Width="420"
                 Height="420"
                 Margin="0,0,-120,-140"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Fill="{StaticResource Brush.DecorGlow}"
                 Opacity="0.75"
                 IsHitTestVisible="False" />

        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="54" />
                <RowDefinition Height="*" />
                <RowDefinition Height="146" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource Surface.CardElevated}"
                    Padding="18,0"
                    MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Width="28"
                                Height="28"
                                Background="{StaticResource Brush.Accent}"
                                CornerRadius="{StaticResource Radius.Pill}" />
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Style="{StaticResource Text.CardTitle}"
                                       Text="{Binding Title}" />
                            <TextBlock Style="{StaticResource Text.Caption}"
                                       Text="{Binding Subtitle}" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Style="{StaticResource Text.Caption}"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Text="Windows desktop music client" />

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource Button.TopBar}"
                                Margin="0,0,6,0"
                                Click="MinimizeButton_Click"
                                Content="&#xE921;" />
                        <Button Style="{StaticResource Button.TopBar}"
                                Margin="0,0,6,0"
                                Click="MaximizeButton_Click"
                                Content="&#xE922;" />
                        <Button Style="{StaticResource Button.TopBar}"
                                Click="CloseButton_Click"
                                Content="&#xE8BB;" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="0,16,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="82" />
                    <ColumnDefinition Width="304" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,0,18,0"
                        Style="{StaticResource Surface.Sidebar}"
                        Padding="10,16">
                    <DockPanel LastChildFill="True">
                        <controls:NavRailProfileButton DockPanel.Dock="Top"
                                                       Initials="N" />

                        <StackPanel DockPanel.Dock="Bottom">
                            <ItemsControl ItemsSource="{Binding FooterNavigation}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <controls:NavRailButton Margin="0,0,0,8"
                                                                Glyph="{Binding Glyph}"
                                                                Label="{Binding Label}"
                                                                IsSelected="{Binding IsSelected}"
                                                                CommandParameter="{Binding}"
                                                                Command="{Binding DataContext.SelectNavigationCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <ItemsControl VerticalAlignment="Center"
                                      ItemsSource="{Binding PrimaryNavigation}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:NavRailButton Margin="0,0,0,8"
                                                            Glyph="{Binding Glyph}"
                                                            Label="{Binding Label}"
                                                            IsSelected="{Binding IsSelected}"
                                                            CommandParameter="{Binding}"
                                                            Command="{Binding DataContext.SelectNavigationCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>

                <controls:LibrarySidebar Grid.Column="1"
                                         Margin="0,0,18,0"
                                         Visibility="{Binding IsLibrarySidebarVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <Border Grid.Column="2"
                        Style="{StaticResource Surface.CardElevated}"
                        Padding="30"
                        ClipToBounds="True">
                    <Grid>
                        <ContentControl x:Name="PageHost"
                                        Content="{Binding CurrentPageViewModel}" />

                        <Border HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Width="320"
                                Padding="16"
                                Background="{StaticResource Brush.PanelRaised}"
                                BorderBrush="{StaticResource Brush.BorderStrong}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Medium}"
                                Visibility="{Binding CurrentNotification, Converter={StaticResource NullToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Text.CardTitle}"
                                           Text="{Binding CurrentNotification.Title}" />
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource Text.Body}"
                                           Text="{Binding CurrentNotification.Body}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Style="{StaticResource Surface.Player}"
                    Padding="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="370" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="332" />
                    </Grid.ColumnDefinitions>

                    <controls:NowPlayingMiniCard Grid.Column="0"
                                                 DataContext="{Binding PlayerBar}" />

                    <StackPanel Grid.Column="1"
                                Margin="30,0"
                                VerticalAlignment="Center">
                        <controls:PlaybackControls DataContext="{Binding PlayerBar}"
                                                   HorizontalAlignment="Center" />
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="54" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"
                                       Style="{StaticResource Text.Caption}"
                                       Text="{Binding PlayerBar.Position, Converter={StaticResource TimeSpanToClockStringConverter}}" />
                            <controls:ProgressSlider Grid.Column="1"
                                                     Margin="10,0"
                                                     Minimum="0"
                                                     Maximum="1"
                                                     Value="{Binding PlayerBar.Progress, Mode=OneWay}"
                                                     PreviewMouseLeftButtonUp="ProgressSlider_PreviewMouseLeftButtonUp" />
                            <TextBlock Grid.Column="2"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Style="{StaticResource Text.Caption}"
                                       Text="{Binding PlayerBar.Duration, Converter={StaticResource TimeSpanToClockStringConverter}}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource Text.Caption}"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   Text="{Binding PlayerBar.PlaybackMessage}" />
                        <StackPanel Margin="0,12,0,0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <TextBlock Margin="0,0,10,0"
                                       VerticalAlignment="Center"
                                       FontFamily="{StaticResource Font.Icon}"
                                       Foreground="{StaticResource Brush.TextMuted}"
                                       Text="&#xE767;" />
                            <controls:VolumeSlider Minimum="0"
                                                   Maximum="1"
                                                   Value="{Binding PlayerBar.Volume, Mode=TwoWay}" />
                            <controls:QueueButton Margin="12,0,0,0"
                                                  ToolTip="{Binding PlayerBar.QueueCount, StringFormat=Queue {0}}" />
                            <controls:OverflowButton Margin="8,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
