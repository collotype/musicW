<Window x:Class="Nocturne.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:Nocturne.App.Controls"
        mc:Ignorable="d"
        Title="Nocturne"
        Width="1560"
        Height="980"
        MinWidth="1280"
        MinHeight="820"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource Brush.AppBackground}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8" />
    </shell:WindowChrome.WindowChrome>

    <Grid PreviewKeyDown="Window_PreviewKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
            <RowDefinition Height="124" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="20,14,20,10"
                Background="{StaticResource Brush.PanelBackground}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="18"
                MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Width="28"
                            Height="28"
                            CornerRadius="14"
                            Background="{StaticResource Brush.Accent}" />
                    <TextBlock Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding Title}" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Style="{StaticResource Text.Caption}"
                           Text="{Binding Subtitle}" />
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Width="34"
                            Height="34"
                            Padding="0"
                            Margin="0,0,6,0"
                            Click="MinimizeButton_Click"
                            Content="&#xE921;"
                            FontFamily="{StaticResource Font.Icon}" />
                    <Button Width="34"
                            Height="34"
                            Padding="0"
                            Margin="0,0,6,0"
                            Click="MaximizeButton_Click"
                            Content="&#xE922;"
                            FontFamily="{StaticResource Font.Icon}" />
                    <Button Width="34"
                            Height="34"
                            Padding="0"
                            Click="CloseButton_Click"
                            Content="&#xE8BB;"
                            FontFamily="{StaticResource Font.Icon}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="20,0,20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="74" />
                <ColumnDefinition Width="286" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,16,0"
                    Background="{StaticResource Brush.PanelBackground}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="28"
                    Padding="10,18">
                <DockPanel LastChildFill="True">
                    <controls:NavRailProfileButton DockPanel.Dock="Top"
                                                   Initials="N" />

                    <StackPanel DockPanel.Dock="Bottom">
                        <ItemsControl ItemsSource="{Binding FooterNavigation}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:NavRailButton Margin="0,0,0,10"
                                                            Glyph="{Binding Glyph}"
                                                            Label="{Binding Label}"
                                                            IsSelected="{Binding IsSelected}"
                                                            CommandParameter="{Binding}"
                                                            Command="{Binding DataContext.SelectNavigationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <ItemsControl VerticalAlignment="Center"
                                  ItemsSource="{Binding PrimaryNavigation}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:NavRailButton Margin="0,0,0,10"
                                                        Glyph="{Binding Glyph}"
                                                        Label="{Binding Label}"
                                                        IsSelected="{Binding IsSelected}"
                                                        CommandParameter="{Binding}"
                                                        Command="{Binding DataContext.SelectNavigationCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <controls:LibrarySidebar Grid.Column="1"
                                     Margin="0,0,16,0"
                                     Visibility="{Binding IsLibrarySidebarVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <Border Grid.Column="2"
                    Background="{StaticResource Brush.ShellBackground}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="32"
                    Padding="24"
                    ClipToBounds="True">
                <Grid>
                    <ContentControl x:Name="PageHost"
                                    Content="{Binding CurrentPageViewModel}" />

                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Visibility="{Binding CurrentNotification, Converter={StaticResource NullToVisibilityConverter}}"
                            Background="{StaticResource Brush.PanelRaised}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="16"
                            Width="280">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource Brush.TextPrimary}"
                                       FontWeight="SemiBold"
                                       Text="{Binding CurrentNotification.Title}" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource Text.Body}"
                                       Text="{Binding CurrentNotification.Body}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="20,0,20,20"
                Background="{StaticResource Brush.PanelElevated}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="30"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>
                <controls:NowPlayingMiniCard Grid.Column="0"
                                             DataContext="{Binding PlayerBar}" />

                <StackPanel Grid.Column="1"
                            Margin="28,0"
                            VerticalAlignment="Center">
                    <controls:PlaybackControls HorizontalAlignment="Center"
                                               DataContext="{Binding PlayerBar}" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="48" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Style="{StaticResource Text.Caption}"
                                   Text="{Binding PlayerBar.Position, Converter={StaticResource TimeSpanToClockStringConverter}}" />
                        <controls:ProgressSlider Grid.Column="1"
                                                 Margin="8,0"
                                                 Minimum="0"
                                                 Maximum="1"
                                                 Value="{Binding PlayerBar.Progress, Mode=OneWay}"
                                                 PreviewMouseLeftButtonUp="ProgressSlider_PreviewMouseLeftButtonUp" />
                        <TextBlock Grid.Column="2"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Style="{StaticResource Text.Caption}"
                                   Text="{Binding PlayerBar.Duration, Converter={StaticResource TimeSpanToClockStringConverter}}" />
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Margin="0,0,8,0"
                            Padding="10"
                            FontFamily="{StaticResource Font.Icon}"
                            Content="&#xE15D;" />
                    <controls:VolumeSlider Minimum="0"
                                           Maximum="1"
                                           Value="{Binding PlayerBar.Volume, Mode=TwoWay}" />
                    <controls:QueueButton Margin="10,0,0,0" />
                    <controls:OverflowButton Margin="8,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
