<UserControl x:Class="Nocturne.App.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource Text.Display}"
                       Text="Settings" />
            <TextBlock Margin="0,10,0,28"
                       Style="{StaticResource Text.Body}"
                       Text="Appearance, audio behavior, cache policy, and provider configuration for the desktop client." />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,14,0">
                    <Border Style="{StaticResource Surface.CardElevated}"
                            Padding="22"
                            Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text.Overline}"
                                       Text="APPEARANCE" />
                            <TextBlock Margin="0,10,0,0"
                                       Style="{StaticResource Text.SectionTitle}"
                                       Text="Client mood and session memory" />
                            <TextBlock Margin="0,14,0,0"
                                       Style="{StaticResource Text.Caption}"
                                       Text="Accent color" />
                            <TextBox Margin="0,8,0,0"
                                     Text="{Binding Settings.AccentColorHex, UpdateSourceTrigger=PropertyChanged}" />
                            <ToggleButton Margin="0,14,0,0"
                                          IsChecked="{Binding Settings.RememberLastSession}"
                                          Content="Remember last session" />
                            <ToggleButton Margin="0,10,0,0"
                                          IsChecked="{Binding Settings.StartMinimized}"
                                          Content="Start minimized" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Surface.CardElevated}"
                            Padding="22"
                            Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text.Overline}"
                                       Text="AUDIO" />
                            <TextBlock Margin="0,10,0,0"
                                       Style="{StaticResource Text.SectionTitle}"
                                       Text="Playback behavior" />
                            <ToggleButton Margin="0,14,0,0"
                                          IsChecked="{Binding Settings.NormalizeAudio}"
                                          Content="Normalization placeholder" />
                            <TextBlock Margin="0,18,0,0"
                                       Style="{StaticResource Text.Caption}"
                                       Text="Language placeholder" />
                            <TextBox Margin="0,8,0,0"
                                     Text="{Binding Settings.LanguageCode, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Surface.CardElevated}"
                            Padding="22">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text.Overline}"
                                       Text="LIBRARY PATHS" />
                            <TextBlock Margin="0,10,0,0"
                                       Style="{StaticResource Text.SectionTitle}"
                                       Text="Music folders and cache" />
                            <TextBlock Margin="0,14,0,0"
                                       Style="{StaticResource Text.Caption}"
                                       Text="Cache folder" />
                            <TextBox Margin="0,8,0,0"
                                     Text="{Binding Settings.CacheFolderPath, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,18,0,0"
                                       Style="{StaticResource Text.Caption}"
                                       Text="Local folders" />
                            <ItemsControl Margin="0,10,0,0"
                                          ItemsSource="{Binding LocalMusicFolders}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Style="{StaticResource Surface.Card}">
                                            <TextBlock Margin="12"
                                                       Style="{StaticResource Text.Body}"
                                                       Text="{Binding}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="14,0,0,0">
                    <Border Style="{StaticResource Surface.CardElevated}"
                            Padding="22"
                            Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text.Overline}"
                                       Text="SOUNDCLOUD" />
                            <TextBlock Margin="0,10,0,0"
                                       Style="{StaticResource Text.SectionTitle}"
                                       Text="Streaming provider" />
                            <ToggleButton Margin="0,14,0,0"
                                          IsChecked="{Binding Settings.SoundCloudEnabled}"
                                          Content="Enable SoundCloud provider" />
                            <ToggleButton Margin="0,10,0,0"
                                          IsChecked="{Binding Settings.DownloadTempStreams}"
                                          Content="Keep downloaded streams" />
                            <TextBlock Margin="0,14,0,0"
                                       Style="{StaticResource Text.Body}"
                                       Text="SoundCloud playback resolves supported stream URLs directly for in-app playback and downloads." />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Surface.CardElevated}"
                            Padding="22"
                            Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text.Overline}"
                                       Text="SPOTIFY" />
                            <TextBlock Margin="0,10,0,0"
                                       Style="{StaticResource Text.SectionTitle}"
                                       Text="Metadata-only provider" />
                            <TextBlock Margin="0,14,0,0"
                                       Style="{StaticResource Text.Caption}"
                                       Text="Client ID" />
                            <TextBox Margin="0,8,0,0"
                                     Text="{Binding Settings.SpotifyClientId, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,14,0,0"
                                       Style="{StaticResource Text.Caption}"
                                       Text="Client secret" />
                            <TextBox Margin="0,8,0,0"
                                     Text="{Binding Settings.SpotifyClientSecret, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,14,0,0"
                                       Style="{StaticResource Text.Caption}"
                                       Text="Market" />
                            <TextBox Margin="0,8,0,0"
                                     Text="{Binding Settings.SpotifyMarket, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Surface.CardElevated}"
                            Padding="22">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text.Overline}"
                                       Text="CACHE AND SESSION" />
                            <TextBlock Margin="0,10,0,0"
                                       Style="{StaticResource Text.SectionTitle}"
                                       Text="Maintenance" />
                            <TextBlock Margin="0,14,0,0"
                                       Style="{StaticResource Text.Body}"
                                       Text="Clear stale artwork and stream metadata, then save the updated desktop configuration." />
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,18,0,0">
                                <Button Content="Save"
                                        Command="{Binding SaveCommand}" />
                                <Button Margin="10,0,0,0"
                                        Style="{StaticResource Button.GhostPill}"
                                        Content="Clear Cache"
                                        Command="{Binding ClearCacheCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
