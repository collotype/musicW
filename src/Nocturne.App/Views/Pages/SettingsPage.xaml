<UserControl x:Class="Nocturne.App.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource Text.Display}"
                       Text="Settings" />
            <TextBlock Margin="0,8,0,28"
                       Style="{StaticResource Text.Body}"
                       Text="Appearance, cache, audio behavior, and online provider configuration." />

            <UniformGrid Columns="2">
                <Border Margin="0,0,14,14"
                        Background="{StaticResource Brush.PanelBackground}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="24"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.SectionTitle}"
                                   Text="Appearance" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource Text.Body}"
                                   Text="Accent color" />
                        <TextBox Margin="0,10,0,0"
                                 Text="{Binding Settings.AccentColorHex, UpdateSourceTrigger=PropertyChanged}" />
                        <ToggleButton Margin="0,12,0,0"
                                      IsChecked="{Binding Settings.RememberLastSession}"
                                      Content="Remember last session" />
                        <ToggleButton Margin="0,10,0,0"
                                      IsChecked="{Binding Settings.StartMinimized}"
                                      Content="Start minimized" />
                    </StackPanel>
                </Border>

                <Border Margin="14,0,0,14"
                        Background="{StaticResource Brush.PanelBackground}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="24"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.SectionTitle}"
                                   Text="Audio" />
                        <ToggleButton Margin="0,14,0,0"
                                      IsChecked="{Binding Settings.NormalizeAudio}"
                                      Content="Normalization placeholder" />
                        <TextBlock Margin="0,16,0,0"
                                   Style="{StaticResource Text.Body}"
                                   Text="Language placeholder" />
                        <TextBox Margin="0,10,0,0"
                                 Text="{Binding Settings.LanguageCode, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>

                <Border Margin="0,0,14,14"
                        Background="{StaticResource Brush.PanelBackground}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="24"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.SectionTitle}"
                                   Text="SoundCloud" />
                        <ToggleButton Margin="0,14,0,0"
                                      IsChecked="{Binding Settings.SoundCloudEnabled}"
                                      Content="Enable SoundCloud provider" />
                        <ToggleButton Margin="0,10,0,0"
                                      IsChecked="{Binding Settings.DownloadTempStreams}"
                                      Content="Keep downloaded streams" />
                        <TextBlock Margin="0,14,0,0"
                                   Style="{StaticResource Text.Body}"
                                   Text="SoundCloud playback resolves playable streams in-app when progressive or supported stream URLs are available." />
                    </StackPanel>
                </Border>

                <Border Margin="14,0,0,14"
                        Background="{StaticResource Brush.PanelBackground}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="24"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.SectionTitle}"
                                   Text="Spotify" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource Text.Body}"
                                   Text="Metadata-only. Playback remains external." />
                        <TextBox Margin="0,12,0,0"
                                 Text="{Binding Settings.SpotifyClientId, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Margin="0,10,0,0"
                                 Text="{Binding Settings.SpotifyClientSecret, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Margin="0,10,0,0"
                                 Text="{Binding Settings.SpotifyMarket, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Background="{StaticResource Brush.PanelBackground}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="24"
                    Padding="20">
                <StackPanel>
                    <TextBlock Style="{StaticResource Text.SectionTitle}"
                               Text="Cache and Library Paths" />
                    <TextBlock Margin="0,10,0,0"
                               Style="{StaticResource Text.Body}"
                               Text="{Binding Settings.CacheFolderPath}" />
                    <ItemsControl Margin="0,14,0,0"
                                  ItemsSource="{Binding LocalMusicFolders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Background="{StaticResource Brush.PanelRaised}"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="12">
                                    <TextBlock Text="{Binding}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal"
                                Margin="0,18,0,0">
                        <Button Content="Save"
                                Command="{Binding SaveCommand}" />
                        <Button Margin="10,0,0,0"
                                Content="Clear Cache"
                                Command="{Binding ClearCacheCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
