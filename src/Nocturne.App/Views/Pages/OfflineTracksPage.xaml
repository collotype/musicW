<UserControl x:Class="Nocturne.App.Views.Pages.OfflineTracksPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Nocturne.App.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource Text.Display}"
                       Text="Offline Tracks" />
            <TextBlock Margin="0,8,0,28"
                       Style="{StaticResource Text.Body}"
                       Text="Files available immediately from disk or saved offline downloads." />

            <controls:EmptyStateView Title="No offline tracks"
                                     Subtitle="Save local files or download supported online tracks to keep them available here.">
                <controls:EmptyStateView.Style>
                    <Style TargetType="controls:EmptyStateView">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Tracks.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </controls:EmptyStateView.Style>
            </controls:EmptyStateView>

            <controls:TrackListView ItemsSource="{Binding Tracks}"
                                    PlayCommand="{Binding PlayTrackCommand}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
