<UserControl x:Class="Nocturne.App.Views.Pages.PlaylistPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Nocturne.App.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <controls:HeroHeader ImageSource="{Binding Playlist.CoverArtUrl}"
                                 CoverArtUrl="{Binding Playlist.CoverArtUrl}"
                                 Kicker="PLAYLIST"
                                 Title="{Binding Playlist.Title}"
                                 Subtitle="{Binding Description}"
                                 Meta="{Binding PlaylistMetaLine}">
                <controls:HeroHeader.ActionsContent>
                    <StackPanel Orientation="Horizontal">
                        <controls:PrimaryPlayButton Content="Play All"
                                                    Command="{Binding PlayAllCommand}" />
                        <Button Margin="10,0,0,0"
                                Style="{StaticResource Button.GhostPill}"
                                Content="Search in Playlist" />
                        <Button Margin="10,0,0,0"
                                Style="{StaticResource Button.GhostPill}"
                                Content="Edit" />
                        <controls:OverflowButton Margin="10,0,0,0" />
                    </StackPanel>
                </controls:HeroHeader.ActionsContent>
            </controls:HeroHeader>

            <Grid Margin="0,24,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource Surface.CardElevated}"
                        Padding="22">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.Overline}"
                                   Text="CURATOR NOTE" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource Text.SectionTitle}"
                                   Text="Why this sequence works" />
                        <TextBlock Margin="0,12,0,0"
                                   Style="{StaticResource Text.Body}"
                                   Text="{Binding Description}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="18,0,0,0"
                        Style="{StaticResource Surface.CardElevated}"
                        Padding="22">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.Overline}"
                                   Text="PLAYBACK PROFILE" />
                        <TextBlock Margin="0,12,0,0"
                                   Style="{StaticResource Text.MetricValue}"
                                   Text="{Binding Playlist.TrackCount}" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource Text.MetricLabel}"
                                   Text="Tracks in sequence" />
                        <TextBlock Margin="0,18,0,0"
                                   Style="{StaticResource Text.MetricValue}"
                                   Text="{Binding Playlist.DurationLabel}" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource Text.MetricLabel}"
                                   Text="Total duration" />
                        <TextBlock Margin="0,18,0,0"
                                   Style="{StaticResource Text.MetricValue}"
                                   Text="{Binding MetadataOnlyTrackCount}" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource Text.MetricLabel}"
                                   Text="Metadata-only tracks" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource Surface.CardElevated}"
                    Padding="20">
                <StackPanel>
                    <controls:SectionHeader Title="Track List" />
                    <controls:TrackListView ItemsSource="{Binding Tracks}"
                                            ActiveTrackId="{Binding DataContext.PlayerBar.CurrentTrack.Id, RelativeSource={RelativeSource AncestorType=Window}}"
                                            PlayCommand="{Binding PlayTrackCommand}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
