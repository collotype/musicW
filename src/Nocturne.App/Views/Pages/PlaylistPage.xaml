<UserControl x:Class="Nocturne.App.Views.Pages.PlaylistPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Nocturne.App.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <controls:HeroHeader ImageSource="{Binding Playlist.CoverArtUrl}"
                                 CoverArtUrl="{Binding Playlist.CoverArtUrl}"
                                 Kicker="Playlist"
                                 Title="{Binding Playlist.Title}"
                                 Subtitle="{Binding Playlist.OwnerName}"
                                 Meta="{Binding Playlist.Tracks.Count, StringFormat={}{0} tracks}">
                <controls:HeroHeader.ActionsContent>
                    <StackPanel Orientation="Horizontal">
                        <controls:PrimaryPlayButton Content="Play All"
                                                    Command="{Binding PlayAllCommand}" />
                        <Button Margin="10,0,0,0"
                                Content="Search in Playlist" />
                        <Button Margin="10,0,0,0"
                                Content="Edit" />
                        <controls:OverflowButton Margin="10,0,0,0" />
                    </StackPanel>
                </controls:HeroHeader.ActionsContent>
            </controls:HeroHeader>

            <Border Margin="0,28,0,0"
                    Background="{StaticResource Brush.PanelBackground}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="28"
                    Padding="18">
                <controls:TrackListView ItemsSource="{Binding Tracks}"
                                        PlayCommand="{Binding PlayTrackCommand}" />
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
