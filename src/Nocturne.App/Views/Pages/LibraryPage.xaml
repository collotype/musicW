<UserControl x:Class="Nocturne.App.Views.Pages.LibraryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Nocturne.App.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource Text.Display}"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,10,0,28"
                       Style="{StaticResource Text.Body}"
                       Text="Pinned essentials, recent additions, and the darker corners of your collection." />

            <UniformGrid Columns="4"
                         Margin="0,0,0,30">
                <Border Margin="0,0,12,0"
                        Style="{StaticResource Surface.CardElevated}"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.Overline}"
                                   Text="FAVORITES" />
                        <TextBlock Margin="0,12,0,0"
                                   Style="{StaticResource Text.MetricValue}"
                                   Text="{Binding FavoriteCount}" />
                        <TextBlock Margin="0,4,0,0"
                                   Style="{StaticResource Text.MetricLabel}"
                                   Text="Liked tracks ready to replay" />
                    </StackPanel>
                </Border>
                <Border Margin="12,0"
                        Style="{StaticResource Surface.CardElevated}"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.Overline}"
                                   Text="OFFLINE" />
                        <TextBlock Margin="0,12,0,0"
                                   Style="{StaticResource Text.MetricValue}"
                                   Text="{Binding OfflineCount}" />
                        <TextBlock Margin="0,4,0,0"
                                   Style="{StaticResource Text.MetricLabel}"
                                   Text="Saved tracks available on disk" />
                    </StackPanel>
                </Border>
                <Border Margin="12,0"
                        Style="{StaticResource Surface.CardElevated}"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.Overline}"
                                   Text="ALBUMS" />
                        <TextBlock Margin="0,12,0,0"
                                   Style="{StaticResource Text.MetricValue}"
                                   Text="{Binding AlbumCount}" />
                        <TextBlock Margin="0,4,0,0"
                                   Style="{StaticResource Text.MetricLabel}"
                                   Text="Full releases in your collection" />
                    </StackPanel>
                </Border>
                <Border Margin="12,0,0,0"
                        Style="{StaticResource Surface.CardElevated}"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.Overline}"
                                   Text="PLAYLISTS" />
                        <TextBlock Margin="0,12,0,0"
                                   Style="{StaticResource Text.MetricValue}"
                                   Text="{Binding PlaylistCount}" />
                        <TextBlock Margin="0,4,0,0"
                                   Style="{StaticResource Text.MetricLabel}"
                                   Text="Curated mixes and saved sequences" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="0.8*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource Surface.CardElevated}"
                        Padding="20">
                    <StackPanel>
                        <controls:SectionHeader Title="Recently Added"
                                                ActionText="Show all" />
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding RecentlyAdded}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <controls:TrackCard Margin="0,0,16,0"
                                                            Track="{Binding}"
                                                            Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="18,0,0,0"
                        Style="{StaticResource Surface.CardElevated}"
                        Padding="20">
                    <StackPanel>
                        <controls:SectionHeader Title="Offline Picks" />
                        <controls:TrackListView ItemsSource="{Binding OfflineTracks}"
                                                ActiveTrackId="{Binding DataContext.PlayerBar.CurrentTrack.Id, RelativeSource={RelativeSource AncestorType=Window}}"
                                                PlayCommand="{Binding PlayTrackCommand}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource Surface.CardElevated}"
                    Padding="20"
                    Margin="0,0,0,30">
                <StackPanel>
                    <controls:SectionHeader Title="Favorites"
                                            ActionText="Open favorites" />
                    <controls:TrackListView ItemsSource="{Binding FavoriteTracks}"
                                            ActiveTrackId="{Binding DataContext.PlayerBar.CurrentTrack.Id, RelativeSource={RelativeSource AncestorType=Window}}"
                                            PlayCommand="{Binding PlayTrackCommand}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Surface.CardElevated}"
                    Padding="20"
                    Margin="0,0,0,30">
                <StackPanel>
                    <controls:SectionHeader Title="Albums"
                                            ActionText="Browse" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Albums}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:AlbumCard Margin="0,0,16,0"
                                                        Album="{Binding}"
                                                        Command="{Binding DataContext.OpenAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Surface.CardElevated}"
                    Padding="20"
                    Margin="0,0,0,30">
                <StackPanel>
                    <controls:SectionHeader Title="Artists"
                                            ActionText="Open all" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Artists}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:ArtistCircleCard Margin="0,0,18,0"
                                                               Artist="{Binding}"
                                                               Command="{Binding DataContext.OpenArtistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Surface.CardElevated}"
                    Padding="20">
                <StackPanel>
                    <controls:SectionHeader Title="Playlists"
                                            ActionText="Manage" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Playlists}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:PlaylistCard Margin="0,0,16,0"
                                                           Playlist="{Binding}"
                                                           Command="{Binding DataContext.OpenPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
