<UserControl x:Class="Nocturne.App.Views.Pages.AlbumPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Nocturne.App.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <controls:HeroHeader ImageSource="{Binding Album.HeaderImageUrl}"
                                 CoverArtUrl="{Binding Album.CoverArtUrl}"
                                 Kicker="ALBUM"
                                 Title="{Binding Album.Title}"
                                 Subtitle="{Binding Album.ArtistName}"
                                 Meta="{Binding AlbumMetaLine}"
                                 Tags="{Binding Album.Genres}">
                <controls:HeroHeader.ActionsContent>
                    <StackPanel Orientation="Horizontal">
                        <controls:PrimaryPlayButton Content="Play All"
                                                    Command="{Binding PlayAllCommand}" />
                        <Button Margin="10,0,0,0"
                                Style="{StaticResource Button.GhostPill}"
                                Content="Shuffle"
                                Command="{Binding ShuffleCommand}" />
                        <Button Margin="10,0,0,0"
                                Style="{StaticResource Button.GhostPill}"
                                Content="Add to Library"
                                Command="{Binding SaveCommand}" />
                        <controls:OverflowButton Margin="10,0,0,0" />
                    </StackPanel>
                </controls:HeroHeader.ActionsContent>
            </controls:HeroHeader>

            <Grid Margin="0,24,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="0.8*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource Surface.CardElevated}"
                        Padding="22">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.Overline}"
                                   Text="DESCRIPTION" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource Text.SectionTitle}"
                                   Text="Release notes" />
                        <TextBlock Margin="0,12,0,0"
                                   Style="{StaticResource Text.Body}"
                                   Text="{Binding Description}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="18,0,0,0"
                        Style="{StaticResource Surface.CardElevated}"
                        Padding="22">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.Overline}"
                                   Text="DETAILS" />
                        <TextBlock Margin="0,12,0,0"
                                   Style="{StaticResource Text.MetricValue}"
                                   Text="{Binding Album.ReleaseYearLabel}" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource Text.MetricLabel}"
                                   Text="Release year" />
                        <TextBlock Margin="0,18,0,0"
                                   Style="{StaticResource Text.MetricValue}"
                                   Text="{Binding Album.TrackCount}" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource Text.MetricLabel}"
                                   Text="Tracks" />
                        <TextBlock Margin="0,18,0,0"
                                   Style="{StaticResource Text.MetricValue}"
                                   Text="{Binding Album.DurationLabel}" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource Text.MetricLabel}"
                                   Text="Duration" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource Surface.CardElevated}"
                    Padding="20">
                <StackPanel>
                    <controls:SectionHeader Title="Track List" />
                    <controls:TrackListView ItemsSource="{Binding Tracks}"
                                            ActiveTrackId="{Binding DataContext.PlayerBar.CurrentTrack.Id, RelativeSource={RelativeSource AncestorType=Window}}"
                                            PlayCommand="{Binding PlayTrackCommand}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
