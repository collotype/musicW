<UserControl x:Class="Nocturne.App.Views.Pages.SearchPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Nocturne.App.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource Text.Display}"
                       Text="Search" />
            <TextBlock Margin="0,10,0,24"
                       Style="{StaticResource Text.Body}"
                       Text="{Binding StatusMessage}" />

            <controls:SearchBar Text="{Binding Query, Mode=TwoWay}"
                                SearchCommand="{Binding SearchCommand}" />

            <ListBox Margin="0,18,0,28"
                     ItemsSource="{Binding SourceOptions}"
                     SelectedItem="{Binding SelectedSourceFilter}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="Margin" Value="0,0,10,0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Chrome"
                                            Background="{StaticResource Brush.PanelBackground}"
                                            BorderBrush="{StaticResource Brush.Border}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Pill}"
                                            Padding="14,8">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Brush.PanelHover}" />
                                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Brush.AccentSoft}" />
                                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Style="{StaticResource Text.Caption}"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   Text="{Binding}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <controls:EmptyStateView Title="No results yet"
                                     Subtitle="Try a broader phrase, or switch to another provider filter.">
                <controls:EmptyStateView.Style>
                    <Style TargetType="controls:EmptyStateView">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasResults}" Value="False">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </controls:EmptyStateView.Style>
            </controls:EmptyStateView>

            <StackPanel Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border Style="{StaticResource Surface.CardElevated}"
                        Padding="20"
                        Margin="0,0,0,28">
                    <StackPanel>
                        <controls:SectionHeader Title="{Binding TrackCount, StringFormat=Tracks ({0})}" />
                        <controls:TrackListView ItemsSource="{Binding Results.Tracks}"
                                                ActiveTrackId="{Binding DataContext.PlayerBar.CurrentTrack.Id, RelativeSource={RelativeSource AncestorType=Window}}"
                                                PlayCommand="{Binding PlayTrackCommand}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Surface.CardElevated}"
                        Padding="20"
                        Margin="0,0,0,28">
                    <StackPanel>
                        <controls:SectionHeader Title="{Binding ArtistCount, StringFormat=Artists ({0})}" />
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Results.Artists}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <controls:ArtistCircleCard Margin="0,0,18,0"
                                                                   Artist="{Binding}"
                                                                   Command="{Binding DataContext.OpenArtistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Surface.CardElevated}"
                        Padding="20"
                        Margin="0,0,0,28">
                    <StackPanel>
                        <controls:SectionHeader Title="{Binding AlbumCount, StringFormat=Albums ({0})}" />
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Results.Albums}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <controls:AlbumCard Margin="0,0,16,0"
                                                            Album="{Binding}"
                                                            Command="{Binding DataContext.OpenAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Surface.CardElevated}"
                        Padding="20">
                    <StackPanel>
                        <controls:SectionHeader Title="{Binding PlaylistCount, StringFormat=Playlists ({0})}" />
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Results.Playlists}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <controls:PlaylistCard Margin="0,0,16,0"
                                                               Playlist="{Binding}"
                                                               Command="{Binding DataContext.OpenPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
