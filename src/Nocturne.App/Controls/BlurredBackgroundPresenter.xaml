<UserControl x:Class="Nocturne.App.Controls.BlurredBackgroundPresenter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border CornerRadius="{Binding CornerRadius, ElementName=Root}"
            ClipToBounds="True">
        <Grid Height="{Binding PresenterHeight, ElementName=Root}">
            <Image Source="{Binding ImageSource, ElementName=Root}"
                   Stretch="UniformToFill"
                   Opacity="0.72">
                <Image.Effect>
                    <BlurEffect Radius="30" />
                </Image.Effect>
            </Image>
            <Rectangle Fill="{StaticResource Brush.HeaderOverlay}" />
            <Rectangle Fill="{StaticResource Brush.HeroFade}" />
        </Grid>
    </Border>
</UserControl>
