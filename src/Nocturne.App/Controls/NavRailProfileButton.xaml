<UserControl x:Class="Nocturne.App.Controls.NavRailProfileButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Width="58"
            Height="72"
            Padding="0,6,0,0"
            Background="Transparent">
        <StackPanel HorizontalAlignment="Center">
            <Grid Width="50"
                  Height="50">
                <Ellipse Fill="{StaticResource Brush.AccentSoft}" />
                <Border Margin="1"
                        Background="{StaticResource Brush.PanelRaised}"
                        BorderBrush="{StaticResource Brush.BorderStrong}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Pill}">
                    <Grid>
                        <Ellipse Margin="6"
                                 Fill="{StaticResource Brush.AccentDark}" />
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.Accent}"
                                   FontWeight="Bold"
                                   Text="{Binding Initials, ElementName=Root}" />
                    </Grid>
                </Border>
                <Ellipse Width="10"
                         Height="10"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Bottom"
                         Fill="{StaticResource Brush.Accent}" />
            </Grid>
            <TextBlock Margin="0,10,0,0"
                       Style="{StaticResource Text.Overline}"
                       Text="NC" />
        </StackPanel>
    </Border>
</UserControl>
