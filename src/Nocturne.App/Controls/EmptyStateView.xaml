<UserControl x:Class="Nocturne.App.Controls.EmptyStateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Background="{StaticResource Brush.PanelBackground}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="24"
            Padding="28">
        <StackPanel>
            <TextBlock Style="{StaticResource Text.SectionTitle}"
                       Text="{Binding Title, ElementName=Root}" />
            <TextBlock Margin="0,8,0,0"
                       Style="{StaticResource Text.Body}"
                       Text="{Binding Subtitle, ElementName=Root}"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>
