<UserControl x:Class="Nocturne.App.Controls.EmptyStateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Style="{StaticResource Surface.CardElevated}"
            Padding="28">
        <StackPanel>
            <Border Width="42"
                    Height="42"
                    Background="{StaticResource Brush.AccentSoft}"
                    BorderBrush="{StaticResource Brush.BorderStrong}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Pill}">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource Font.Icon}"
                           Foreground="{StaticResource Brush.Accent}"
                           Text="&#xE838;" />
            </Border>
            <TextBlock Margin="0,18,0,0"
                       Style="{StaticResource Text.SectionTitle}"
                       Text="{Binding Title, ElementName=Root}" />
            <TextBlock Margin="0,8,0,0"
                       Style="{StaticResource Text.Body}"
                       Text="{Binding Subtitle, ElementName=Root}"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>
