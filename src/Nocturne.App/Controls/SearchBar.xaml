<UserControl x:Class="Nocturne.App.Controls.SearchBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Style="{StaticResource Surface.CardElevated}"
            Padding="16,10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Width="34"
                    Height="34"
                    Background="{StaticResource Brush.PanelContrast}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Pill}"
                    VerticalAlignment="Center">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource Font.Icon}"
                           Foreground="{StaticResource Brush.TextMuted}"
                           Text="&#xE721;" />
            </Border>

            <Grid Grid.Column="1"
                  Margin="14,0,14,0">
                <TextBox Style="{StaticResource TextBox.ChromeLess}"
                         Text="{Binding Text, ElementName=Root, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         KeyDown="Input_KeyDown" />
                <TextBlock IsHitTestVisible="False"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.TextMuted}"
                           Text="{Binding Placeholder, ElementName=Root}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=Root}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Button Grid.Column="2"
                    Background="{StaticResource Brush.Accent}"
                    BorderBrush="{StaticResource Brush.Accent}"
                    Foreground="{StaticResource Brush.AccentDark}"
                    Command="{Binding SearchCommand, ElementName=Root}"
                    Content="Search"
                    Padding="16,11" />
        </Grid>
    </Border>
</UserControl>
