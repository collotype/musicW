<UserControl x:Class="Nocturne.App.Controls.SectionHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
            <TextBlock Style="{StaticResource Text.Overline}"
                       Text="SECTION" />
            <TextBlock Margin="0,6,0,0"
                       Style="{StaticResource Text.SectionTitle}"
                       Text="{Binding Title, ElementName=Root}" />
        </StackPanel>

        <Button Grid.Column="1"
                Style="{StaticResource Button.Text}"
                Command="{Binding ActionCommand, ElementName=Root}"
                Visibility="{Binding ActionText, ElementName=Root, Converter={StaticResource NullToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Style="{StaticResource Text.Action}"
                           Text="{Binding ActionText, ElementName=Root}" />
                <TextBlock Margin="6,0,0,0"
                           FontFamily="{StaticResource Font.Icon}"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           Text="&#xE76C;" />
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
