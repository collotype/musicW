<UserControl x:Class="Nocturne.App.Controls.SectionHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid Margin="0,0,0,14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
                   Style="{StaticResource Text.SectionTitle}"
                   Text="{Binding Title, ElementName=Root}" />
        <Button Grid.Column="1"
                Background="Transparent"
                BorderThickness="0"
                Command="{Binding ActionCommand, ElementName=Root}"
                Content="{Binding ActionText, ElementName=Root}"
                Foreground="{StaticResource Brush.TextSecondary}"
                Visibility="{Binding ActionText, ElementName=Root, Converter={StaticResource NullToVisibilityConverter}}" />
    </Grid>
</UserControl>
