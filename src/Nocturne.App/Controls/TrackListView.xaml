<UserControl x:Class="Nocturne.App.Controls.TrackListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Nocturne.App.Controls"
             x:Name="Root">
    <ListBox ItemsSource="{Binding ItemsSource, ElementName=Root}">
        <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
                <VirtualizingStackPanel />
            </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemTemplate>
            <DataTemplate>
                <controls:TrackRowControl Track="{Binding}"
                                          PlayCommand="{Binding PlayCommand, ElementName=Root}" />
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>
