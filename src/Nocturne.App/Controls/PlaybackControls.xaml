<UserControl x:Class="Nocturne.App.Controls.PlaybackControls"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Nocturne.App.Controls"
             xmlns:enums="clr-namespace:Nocturne.App.Models.Enums">
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center">
        <controls:GhostIconButton Content="&#xE8EE;"
                                  Command="{Binding ToggleShuffleCommand}">
            <controls:GhostIconButton.Style>
                <Style TargetType="controls:GhostIconButton" BasedOn="{StaticResource {x:Type controls:GhostIconButton}}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsShuffleEnabled}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Brush.Accent}" />
                            <Setter Property="Background" Value="{StaticResource Brush.AccentSoft}" />
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </controls:GhostIconButton.Style>
        </controls:GhostIconButton>

        <controls:GhostIconButton Margin="10,0,0,0"
                                  Content="&#xE892;"
                                  Command="{Binding PreviousCommand}" />

        <controls:PrimaryPlayButton Margin="12,0,0,0"
                                    Width="56"
                                    Height="56"
                                    Padding="0"
                                    FontFamily="{StaticResource Font.Icon}"
                                    Command="{Binding PlayPauseCommand}">
            <controls:PrimaryPlayButton.Style>
                <Style TargetType="controls:PrimaryPlayButton" BasedOn="{StaticResource {x:Type controls:PrimaryPlayButton}}">
                    <Setter Property="Content" Value="&#xE768;" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                            <Setter Property="Content" Value="&#xF8AE;" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </controls:PrimaryPlayButton.Style>
        </controls:PrimaryPlayButton>

        <controls:GhostIconButton Margin="12,0,0,0"
                                  Content="&#xE893;"
                                  Command="{Binding NextCommand}" />

        <controls:GhostIconButton Margin="10,0,0,0"
                                  Command="{Binding CycleRepeatCommand}"
                                  Content="{Binding RepeatMode, Converter={StaticResource RepeatModeToGlyphConverter}}">
            <controls:GhostIconButton.Style>
                <Style TargetType="controls:GhostIconButton" BasedOn="{StaticResource {x:Type controls:GhostIconButton}}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding RepeatMode}" Value="{x:Static enums:RepeatMode.All}">
                            <Setter Property="Foreground" Value="{StaticResource Brush.Accent}" />
                            <Setter Property="Background" Value="{StaticResource Brush.AccentSoft}" />
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RepeatMode}" Value="{x:Static enums:RepeatMode.One}">
                            <Setter Property="Foreground" Value="{StaticResource Brush.Accent}" />
                            <Setter Property="Background" Value="{StaticResource Brush.AccentSoft}" />
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </controls:GhostIconButton.Style>
        </controls:GhostIconButton>
    </StackPanel>
</UserControl>
