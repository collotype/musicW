<UserControl x:Class="Nocturne.App.Controls.NowPlayingMiniCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Nocturne.App.Controls">
    <Border Style="{StaticResource Surface.CardElevated}"
            Padding="14">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Width="58"
                    Height="58"
                    Background="{StaticResource Brush.PanelContrast}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Large}"
                    ClipToBounds="True">
                <Image Source="{Binding CurrentTrack.CoverArtUrl}"
                       Stretch="UniformToFill" />
            </Border>

            <StackPanel Grid.Column="1"
                        Margin="14,0,0,0"
                        VerticalAlignment="Center">
                <TextBlock Style="{StaticResource Text.CardTitle}"
                           Text="{Binding CurrentTrack.Title, TargetNullValue=Nothing Playing}"
                           TextTrimming="CharacterEllipsis" />
                <Button Margin="0,4,0,0"
                        Style="{StaticResource Button.Text}"
                        Command="{Binding OpenArtistCommand}"
                        HorizontalAlignment="Left">
                    <TextBlock Style="{StaticResource Text.Caption}"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Text="{Binding CurrentTrack.ArtistName, TargetNullValue=Queue a track}" />
                </Button>
                <StackPanel Margin="0,8,0,0"
                            Orientation="Horizontal">
                    <Border Padding="8,5"
                            Background="#12000000"
                            BorderBrush="{StaticResource Brush.BorderStrong}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Pill}">
                        <TextBlock Style="{StaticResource Text.Caption}"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   Text="{Binding CurrentSourceLabel}" />
                    </Border>
                    <Border Margin="8,0,0,0"
                            Padding="8,5"
                            Background="#12000000"
                            BorderBrush="{StaticResource Brush.BorderStrong}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Pill}">
                        <TextBlock Style="{StaticResource Text.Caption}"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   Text="{Binding AvailabilityLabel}" />
                    </Border>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Margin="12,0,0,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <controls:FavoriteToggleButton IsChecked="{Binding CurrentTrack.IsLiked}"
                                               Command="{Binding ToggleLikeCommand}" />
                <controls:GhostIconButton Margin="8,0,0,0"
                                          Command="{Binding OpenAlbumCommand}"
                                          Content="&#xE14C;" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
