<UserControl x:Class="Nocturne.App.Controls.AlbumCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Button Command="{Binding Command, ElementName=Root}"
            CommandParameter="{Binding Album, ElementName=Root}"
            Background="Transparent"
            BorderThickness="0"
            Padding="0"
            Width="232">
        <Border x:Name="Chrome"
                Padding="14">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource Surface.CardElevated}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                            <Setter Property="Background" Value="{StaticResource Brush.PanelHover}" />
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <Grid Height="170"
                      ClipToBounds="True">
                    <Border CornerRadius="{StaticResource Radius.Large}"
                            ClipToBounds="True">
                        <Grid>
                            <Image Source="{Binding Album.CoverArtUrl, ElementName=Root}"
                                   Stretch="UniformToFill" />
                            <Rectangle Fill="{StaticResource Brush.CardImageOverlay}" />
                        </Grid>
                    </Border>
                    <Border HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="12"
                            Padding="10,6"
                            Background="#72000000"
                            BorderBrush="{StaticResource Brush.BorderStrong}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Pill}">
                        <TextBlock Style="{StaticResource Text.Caption}"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   Text="{Binding Album.ReleaseYearLabel, ElementName=Root}" />
                    </Border>
                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="12"
                            Padding="10,6"
                            Background="#70000000"
                            BorderBrush="{StaticResource Brush.BorderStrong}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Pill}">
                        <TextBlock Style="{StaticResource Text.Caption}"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   Text="{Binding Album.TrackCount, ElementName=Root, StringFormat={}{0} tracks}" />
                    </Border>
                </Grid>
                <TextBlock Margin="0,16,0,0"
                           Style="{StaticResource Text.CardTitle}"
                           Text="{Binding Album.Title, ElementName=Root}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource Text.BodyMuted}"
                           Text="{Binding Album.ArtistName, ElementName=Root}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Margin="0,10,0,0"
                           Style="{StaticResource Text.Caption}"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           Text="{Binding Album.DurationLabel, ElementName=Root}" />
            </StackPanel>
        </Border>
    </Button>
</UserControl>
