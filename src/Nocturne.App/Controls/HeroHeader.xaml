<UserControl x:Class="Nocturne.App.Controls.HeroHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Nocturne.App.Controls"
             x:Name="Root">
    <Border CornerRadius="{StaticResource Radius.XLarge}"
            ClipToBounds="True">
        <Grid MinHeight="360">
            <controls:BlurredBackgroundPresenter ImageSource="{Binding ImageSource, ElementName=Root}"
                                                 PresenterHeight="380"
                                                 CornerRadius="38" />
            <Rectangle Fill="{StaticResource Brush.HeaderOverlay}" />
            <Rectangle Fill="{StaticResource Brush.HeroFade}" />
            <Border BorderBrush="{StaticResource Brush.BorderStrong}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.XLarge}" />

            <Grid Margin="34">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.RowSpan="2"
                        Width="188"
                        Height="188"
                        VerticalAlignment="Bottom"
                        Background="{StaticResource Brush.PanelContrast}"
                        BorderBrush="{StaticResource Brush.BorderStrong}"
                        BorderThickness="1"
                        ClipToBounds="True"
                        Effect="{StaticResource Effect.HeroCoverShadow}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="{StaticResource Radius.Large}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCircularCover, ElementName=Root}" Value="True">
                                    <Setter Property="CornerRadius" Value="{StaticResource Radius.Pill}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Image Source="{Binding CoverArtUrl, ElementName=Root}"
                           Stretch="UniformToFill" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="12,18,0,0"
                            VerticalAlignment="Bottom">
                    <TextBlock Style="{StaticResource Text.Overline}"
                               Text="{Binding Kicker, ElementName=Root}" />
                    <TextBlock Margin="0,10,0,0"
                               Style="{StaticResource Text.HeroTitle}"
                               Text="{Binding Title, ElementName=Root}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,10,0,0"
                               Style="{StaticResource Text.Body}"
                               Text="{Binding Subtitle, ElementName=Root}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,12,0,0"
                               Style="{StaticResource Text.Caption}"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Text="{Binding Meta, ElementName=Root}" />
                    <ItemsControl Margin="0,18,0,0"
                                  ItemsSource="{Binding Tags, ElementName=Root}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:TagChip Text="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <ContentPresenter Grid.Row="1"
                                  Grid.Column="1"
                                  Margin="12,26,0,0"
                                  Content="{Binding ActionsContent, ElementName=Root}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
