<UserControl x:Class="Nocturne.App.Controls.ArtistCircleCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Button Command="{Binding Command, ElementName=Root}"
            CommandParameter="{Binding Artist, ElementName=Root}"
            Background="Transparent"
            BorderThickness="0"
            Padding="0"
            Width="154">
        <StackPanel>
            <Border Width="120"
                    Height="120"
                    HorizontalAlignment="Center"
                    CornerRadius="60"
                    ClipToBounds="True"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1">
                <Image Source="{Binding Artist.AvatarUrl, ElementName=Root}" Stretch="UniformToFill" />
            </Border>
            <TextBlock Margin="0,14,0,0"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       HorizontalAlignment="Center"
                       FontWeight="SemiBold"
                       Text="{Binding Artist.Name, ElementName=Root}" />
            <TextBlock Margin="0,4,0,0"
                       HorizontalAlignment="Center"
                       Style="{StaticResource Text.Caption}"
                       Text="{Binding Artist.MonthlyListeners, ElementName=Root, StringFormat={}{0:N0} listeners}" />
        </StackPanel>
    </Button>
</UserControl>
