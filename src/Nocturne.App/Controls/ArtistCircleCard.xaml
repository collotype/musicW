<UserControl x:Class="Nocturne.App.Controls.ArtistCircleCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Button Command="{Binding Command, ElementName=Root}"
            CommandParameter="{Binding Artist, ElementName=Root}"
            Background="Transparent"
            BorderThickness="0"
            Padding="0"
            Width="168">
        <StackPanel>
            <Grid Width="136"
                  Height="136"
                  HorizontalAlignment="Center">
                <Ellipse Fill="{StaticResource Brush.DecorGlow}"
                         Opacity="0.75" />
                <Border Margin="8"
                        Background="{StaticResource Brush.PanelContrast}"
                        BorderBrush="{StaticResource Brush.BorderStrong}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Pill}"
                        ClipToBounds="True">
                    <Image Source="{Binding Artist.AvatarUrl, ElementName=Root}"
                           Stretch="UniformToFill" />
                </Border>
            </Grid>
            <TextBlock Margin="0,14,0,0"
                       Style="{StaticResource Text.CardTitle}"
                       HorizontalAlignment="Center"
                       Text="{Binding Artist.Name, ElementName=Root}"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock Margin="0,6,0,0"
                       Style="{StaticResource Text.Caption}"
                       HorizontalAlignment="Center"
                       Text="{Binding Artist.MonthlyListeners, ElementName=Root, StringFormat={}{0:N0} monthly}" />
        </StackPanel>
    </Button>
</UserControl>
