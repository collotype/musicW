<UserControl x:Class="Nocturne.App.Controls.NavRailButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Nocturne.App.Controls"
             x:Name="Root">
    <Button Command="{Binding Command, ElementName=Root}"
            CommandParameter="{Binding CommandParameter, ElementName=Root}"
            ToolTip="{Binding Label, ElementName=Root}"
            Width="52"
            Height="52"
            Background="Transparent"
            BorderThickness="0"
            Padding="0">
        <Border CornerRadius="18">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="Transparent" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelected, ElementName=Root}" Value="True">
                            <Setter Property="Background" Value="#20B7F9E4" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock FontFamily="{StaticResource Font.Icon}"
                       FontSize="18"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Text="{Binding Glyph, ElementName=Root}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected, ElementName=Root}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>
    </Button>
</UserControl>
