<UserControl x:Class="Nocturne.App.Controls.NavRailButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Button Command="{Binding Command, ElementName=Root}"
            CommandParameter="{Binding CommandParameter, ElementName=Root}"
            ToolTip="{Binding Label, ElementName=Root}"
            Width="58"
            Height="62"
            Background="Transparent"
            BorderThickness="0"
            Padding="0">
        <Grid>
            <Border x:Name="Indicator"
                    Width="4"
                    Height="24"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="{StaticResource Brush.Accent}"
                    CornerRadius="{StaticResource Radius.Pill}"
                    Opacity="0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Opacity" Value="0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected, ElementName=Root}" Value="True">
                                <Setter Property="Opacity" Value="1" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
            <Border x:Name="Chrome"
                    Margin="8,4,2,4"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Medium}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                <Setter Property="Background" Value="#12000000" />
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected, ElementName=Root}" Value="True">
                                <Setter Property="Background" Value="{StaticResource Brush.NavSelection}" />
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Ellipse x:Name="Halo"
                             Width="28"
                             Height="28"
                             Fill="{StaticResource Brush.AccentSoft}"
                             Opacity="0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Opacity" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected, ElementName=Root}" Value="True">
                                        <Setter Property="Opacity" Value="1" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontFamily="{StaticResource Font.Icon}"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="{Binding Glyph, ElementName=Root}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected, ElementName=Root}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>
    </Button>
</UserControl>
