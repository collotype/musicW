<UserControl x:Class="Nocturne.App.Controls.SidebarCollectionItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Button Command="{Binding Command, ElementName=Root}"
            CommandParameter="{Binding Item, ElementName=Root}"
            Background="Transparent"
            BorderThickness="0"
            Padding="0"
            HorizontalContentAlignment="Stretch">
        <Border Padding="12"
                CornerRadius="18"
                Background="Transparent"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                Margin="0,0,0,8">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{StaticResource Brush.PanelBackground}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Item.IsSelected, ElementName=Root}" Value="True">
                            <Setter Property="Background" Value="#1FB7F9E4" />
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="38"
                        Height="38"
                        CornerRadius="12"
                        Background="{StaticResource Brush.PanelRaised}"
                        ClipToBounds="True">
                    <Grid>
                        <Image Source="{Binding Item.CoverArtUrl, ElementName=Root}" Stretch="UniformToFill" />
                        <TextBlock FontFamily="{StaticResource Font.Icon}"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="{Binding Item.Glyph, ElementName=Root}" />
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding Item.Title, ElementName=Root}"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource Text.Caption}"
                               Text="{Binding Item.Subtitle, ElementName=Root}" />
                </StackPanel>
            </Grid>
        </Border>
    </Button>
</UserControl>
