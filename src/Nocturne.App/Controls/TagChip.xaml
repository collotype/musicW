<UserControl x:Class="Nocturne.App.Controls.TagChip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Background="#12000000"
            BorderBrush="{StaticResource Brush.BorderStrong}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.Pill}"
            Padding="12,7"
            Margin="0,0,8,8">
        <TextBlock Style="{StaticResource Text.Caption}"
                   Foreground="{StaticResource Brush.TextSecondary}"
                   Text="{Binding Text, ElementName=Root}" />
    </Border>
</UserControl>
